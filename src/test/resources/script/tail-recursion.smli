(* Simple tail recursion ------------------------------------------
 * resum: a simple tail-recursive accumulator.
 * Needs TCO to handle large inputs (depth > ~1,000).
 *)
let
  fun resum (m, n) =
    if m = 0 then n
    else resum (m - 1, n + 1)
in
  resum (1000, 0)
end;
> val it = 1000 : int

let fun resum (m, n) = if m = 0 then n else resum (m - 1, n + 1)
in resum (1000000, 0) end;
> val it = 1000000 : int

(* Coprime numbers -------------------------------------------------------
 * coprime: tests whether two numbers are coprime.
 * a and b are coprime if their greatest common divisor is 1.
 * Uses mutual tail recursion.
 *)
fun coprime (a, b) =
  if a < 1 orelse b < 1 then false
  else if a = 1 orelse b = 1 then true
  else if a < b then coprime (a, b mod a)
  else if a > b then coprime (a mod b, b)
  else false;
> val coprime = fn : int * int -> bool

coprime (3, 2);
> val it = true : bool

coprime (6, 1);
> val it = true : bool

coprime (1, 8);
> val it = true : bool

coprime (~6, 2);
> val it = false : bool

coprime (15, 3);
> val it = false : bool

coprime (15, 6);
> val it = false : bool

coprime (6, 15);
> val it = false : bool

coprime (21, 10);
> val it = true : bool

(*) the 46th and 45th terms in the fibonacci sequence
coprime (1836311903, 1134903170);
> val it = true : bool

(* N-queens --------------------------------------------------------
 * N-queens: find one solution to the N-queens puzzle.
 * Based on https://rosettacode.org/wiki/N-queens_problem#Standard_ML
 * See https://github.com/hydromatic/morel/issues/148.
 *)

(*) 'threat' returns true iff two queens threaten each other.
fun threat (x, y) (x', y') =
  x = x' orelse y = y' orelse abs (x - x') = abs (y - y');
> val threat = fn : int * int -> int * int -> bool

(*) 'conflict' returns true if a position conflicts with any queen in the list.
fun conflict pos = List.`exists` (threat pos);
> val conflict = fn : int * int -> (int * int) list -> bool

(*) 'addQueen' tries to place a queen in row i using continuations.
(*) 'try' and 'addQueen' are mutually tail-recursive so depth is O(n).
fun addQueen (i, n, qs, fc) =
  let
    fun try j =
      if j > n then fc ()
      else if conflict (i, j) qs then try (j + 1)
      else if i = n then SOME ((i, j) :: qs)
      else addQueen (i + 1, n, (i, j) :: qs, fn () => try (j + 1))
  in
    try 1
  end;
> val addQueen = fn
>   : int * int * (int * int) list * (unit -> (int * int) list option)
>     -> (int * int) list option

fun queens n = addQueen (1, n, [], fn () => NONE);
> val queens = fn : int -> (int * int) list option

(*) No solution for n=2.
queens 2;
> val it = NONE : (int * int) list option

(*) One solution for n=6.
queens 6;
> val it = SOME [(6,5),(5,3),(4,1),(3,6),(2,4),(1,2)] : (int * int) list option

(*) One solution for n=8.
queens 8;
> val it = SOME [(8,4),(7,2),(6,7),(5,3),(4,6),(3,8),(2,5),(1,1)] : (int * int) list option

(*) One solution for n=12.
queens 12;
> val it =
>   SOME [(12,4),(11,9),(10,7),(9,2),(8,11),(7,6),(6,12),(5,10),(4,8),(3,5),(2,3),
>    (1,1)] : (int * int) list option

(*) queens 100 is correct but takes too long to run.
(*) queens 100;
(*) > val it = SOME [...] : (int * int) list option

(* Mutual tail recursion ------------------------------------------
 * Mutual tail recursion: even/odd parity test.
 * Uses 'fun ... and ...' to declare two mutually tail-recursive functions.
 *)
fun even n = if n = 0 then true else odd (n - 1)
and odd n = if n = 0 then false else even (n - 1);
> val even = fn : int -> bool
> val odd = fn : int -> bool

even 0;
> val it = true : bool

even 1;
> val it = false : bool

odd 3;
> val it = true : bool

(*) Large inputs require TCO to avoid stack overflow.
even 100000;
> val it = true : bool

odd 100000;
> val it = false : bool

odd 99999;
> val it = true : bool

(*) End tail-recursion.smli
