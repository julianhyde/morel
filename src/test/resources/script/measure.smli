 *
 * Tests for measures and their context-dependent methods.
 *
 * The 'context' keyword provides the match-all base context within a
 * query. Evaluating a measure ('eval', 'evaluate'), the accessors
 * ('test', 'paramOf', 'toString'), and the modifiers ('restrict',
 * 'restrict_anon', 'relax', 'override') all work against it.
 *)
val data = bag [1, 2, 3];
> val data = [1,2,3] : int bag
val sumM = Table.measure
  (fn c => from r in data where Table.test (c, r) compute sum over r);
> val sumM = measure : ('a,int,unit,int) measure

(* Evaluate the measure against the base context, in prefix then postfix
   form. The base context matches every element, so each row gets the total
   of the whole bag. *)
from e in data yield Table.evaluate (sumM, (), context);
> val it = [6,6,6] : int bag
from e in data yield sumM.evaluate ((), context);
> val it = [6,6,6] : int bag

(*) The base context has no constraints, so 'toString' renders the empty set.
from e in data yield Table.toString context;
> val it = ["{}","{}","{}"] : string bag
from e in data yield context.toString ();
> val it = ["{}","{}","{}"] : string bag

(*) Its parameter is unit.
from e in data yield Table.paramOf context;
> val it = [(),(),()] : unit bag
from e in data yield context.paramOf ();
> val it = [(),(),()] : unit bag

(*) 'test' admits every base element.
from e in data yield Table.test (context, e);
> val it = [true,true,true] : bool bag
from e in data yield context.test e;
> val it = [true,true,true] : bool bag

(*) The keyword's type depends on the query's element type.
from e in data yield type_string context;
> val it = ["(unit,int) cx","(unit,int) cx","(unit,int) cx"] : string bag

(*) 'context' is only valid in a query.
context;
> stdIn:1.1-1.8 Error: 'context' is only valid in a query
>   raised at: stdIn:1.1-1.8
val c = context;
> stdIn:1.9-1.16 Error: 'context' is only valid in a query
>   raised at: stdIn:1.9-1.16

(* A query may iterate a table directly. An unordered (bag-backed) table
   yields an unordered query; an ordered (list-backed) table yields an
   ordered one. *)
val ut = Table.table (bag [{x = 1}, {x = 2}, {x = 3}], {n = 10});
> val ut = table : ({n:int},{x:int},unordered) table
from e in ut yield e.x;
> val it = [1,2,3] : int bag
val ot = Table.orderedTable ([{x = 1}, {x = 2}, {x = 3}], {n = 10});
> val ot = table : ({n:int},{x:int},ordered) table
from e in ot yield e.x;
> val it = [1,2,3] : int list

(* The context's type carries the table's parameter and element types; the
   orderedness flows to the query collection. *)
type_string (from e in ut yield context);
> val it = "({n:int},{x:int}) cx bag" : string
type_string (from e in ot yield context);
> val it = "({n:int},{x:int}) cx list" : string

(*) 'paramOf' on a table query's context returns the table's parameter.
from e in ut yield Table.paramOf context;
> val it = [{n=10},{n=10},{n=10}] : {n:int} bag
from e in ut yield context.paramOf ();
> val it = [{n=10},{n=10},{n=10}] : {n:int} bag

(*) A non-table source has a unit parameter.
from e in [1, 2, 3] yield Table.paramOf context;
> val it = [(),(),()] : unit list

(* In a 'group ... compute' clause, 'context' is constrained to the group's
   key. 'toString' renders each key as an equality item, and 'test' admits
   only rows that belong to the group. *)
val prods =
  bag [{color = "red", units = 10}, {color = "red", units = 4},
       {color = "blue", units = 7}];
> val prods =
>   [{color="red",units=10},{color="red",units=4},{color="blue",units=7}]
>   : {color:string, units:int} bag
from e in prods group {e.color} compute {c = context.toString ()};
> val it =
>   [{c="{e.color = \"red\"}",color="red"},
>    {c="{e.color = \"blue\"}",color="blue"}] : {c:string, color:string} bag
from e in prods
  group {e.color}
  compute {t = context.test {color = "red", units = 0}};
> val it = [{color="red",t=true},{color="blue",t=false}]
>   : {color:string, t:bool} bag

(*) Several keys render as sorted equality items.
from e in prods group {e.color, e.units} compute {c = context.toString ()};
> val it =
>   [{c="{e.color = \"red\", e.units = 10}",color="red",units=10},
>    {c="{e.color = \"red\", e.units = 4}",color="red",units=4},
>    {c="{e.color = \"blue\", e.units = 7}",color="blue",units=7}]
>   : {c:string, color:string, units:int} bag

(* A 'where' before the measure adds a filter to the context: 'toString'
   renders the predicate, and 'test' applies it. *)
from e in prods where e.units > 5 yield context.toString ();
> val it = ["{e.units > 5}","{e.units > 5}"] : string bag
from e in prods
  where e.units > 5
  yield context.test {color = "x", units = 1};
> val it = [false,false] : bool bag
from e in prods
  where e.units > 5
  yield context.test {color = "x", units = 9};
> val it = [true,true] : bool bag

(*) A 'where' filter and a group key both appear, sorted.
from e in prods
  where e.units > 5
  group {e.color}
  compute {c = context.toString ()};
> val it =
>   [{c="{e.color = \"red\", e.units > 5}",color="red"},
>    {c="{e.color = \"blue\", e.units > 5}",color="blue"}]
>   : {c:string, color:string} bag

(* A string literal in the predicate is rendered verbatim, even one that
   contains a '#word word' pattern that looks like a field selector. *)
from e in prods where e.color <> "#x y" yield context.toString ();
> val it =
>   ["{e.color <> \"#x y\"}","{e.color <> \"#x y\"}","{e.color <> \"#x y\"}"]
>   : string bag

(* 'eval' evaluates a measure against the surrounding context. In a group the
   context is constrained to the group's key, so the measure sees only that
   group's rows and computes a per-group total. 'eval (m, a)' is sugar for
   'evaluate (m, a, context)'; the postfix form 'm.eval a' works too. *)
val sumU =
  Table.measure
    (fn c => from r in prods where Table.test (c, r) compute sum over r.units);
> val sumU = measure : ('a,{color:string, units:int},unit,int) measure
from e in prods group {e.color} compute {total = Table.eval (sumU, ())};
> val it = [{color="red",total=14},{color="blue",total=7}]
>   : {color:string, total:int} bag
from e in prods group {e.color} compute {total = sumU.eval ()};
> val it = [{color="red",total=14},{color="blue",total=7}]
>   : {color:string, total:int} bag

(* 'restrict' and 'restrict_anon' add a filter to the context a measure sees,
   narrowing which base rows it aggregates; 'restrict' labels the filter. *)

(* 'restrict_anon' narrows the sum: within each group only rows with units > 5
   count, so red loses its units = 4 row (14 becomes 10). *)
val bigU = sumU.restrict_anon (fn e => e.units > 5);
> val bigU = measure : ('a,{color:string, units:int},unit,int) measure
from e in prods group {e.color} compute {total = bigU.eval ()};
> val it = [{color="red",total=10},{color="blue",total=7}]
>   : {color:string, total:int} bag

(* 'toString' shows the added filter: 'restrict_anon' renders just the
   predicate, 'restrict' renders 'label: predicate'. *)
val ctxS = Table.measure (fn c => Table.toString c);
> val ctxS = measure : ('a,'b,unit,string) measure
from e in prods group {e.color}
  compute {s = (ctxS.restrict ("big", fn e => e.units > 5)).eval ()};
> val it =
>   [{color="red",s="{big: e.units > 5, e.color = \"red\"}"},
>    {color="blue",s="{big: e.units > 5, e.color = \"blue\"}"}]
>   : {color:string, s:string} bag

(* 'relax' removes a modifier (by label) from the context. Relaxing a group key
   lets the measure see all rows again, so 'whole' is the grand total (21)
   against each group's 'part' - the basis of a percent-of-total. *)
from e in prods
  group {e.color}
  compute {part = sumU.eval (), whole = (sumU.relax "e.color").eval ()};
> val it = [{color="red",part=14,whole=21},{color="blue",part=7,whole=21}]
>   : {color:string, part:int, whole:int} bag
(*) 'toString' confirms the relaxed context is empty.
from e in prods group {e.color} compute {s = (ctxS.relax "e.color").eval ()};
> val it = [{color="red",s="{}"},{color="blue",s="{}"}]
>   : {color:string, s:string} bag

(* 'override' replaces the equality on a projected label - a what-if. Overriding
   the group key makes the measure see that group: the sum for "blue" (7),
   whatever the row's actual color. *)
from e in prods
  group {e.color}
  compute {ctx = (ctxS.override (fn e => e.color, "blue")).eval (),
           blue = (sumU.override (fn e => e.color, "blue")).eval ()};
> val it =
>   [{blue=7,color="red",ctx="{e.color = \"blue\"}"},
>    {blue=7,color="blue",ctx="{e.color = \"blue\"}"}]
>   : {blue:int, color:string, ctx:string} bag

(* A later override on the same label wins, whether reached by the fold
   ('override; override') or by relaxing in between ('override; relax;
   override'). Both give "green". *)
from e in prods
  group {e.color}
  compute {
    folded = ((ctxS.override (fn e => e.color, "red"))
                .override (fn e => e.color, "green")).eval (),
    relaxed = (((ctxS.override (fn e => e.color, "red")).relax "e.color")
                .override (fn e => e.color, "green")).eval ()};
> val it =
>   [{color="red",folded="{e.color = \"green\"}",
>     relaxed="{e.color = \"green\"}"},
>    {color="blue",folded="{e.color = \"green\"}",
>     relaxed="{e.color = \"green\"}"}]
>   : {color:string, folded:string, relaxed:string} bag

(* The 'at {...}' sugar applies the same context modifiers as the postfix
   methods, but reads left-to-right. Each entry desugars to one modifier: a bare
   predicate to 'restrict_anon', 'label: pred' to a labeled 'restrict', 'relax
   e.field' to 'relax', and 'e.field = value' to 'override'. *)

(* A bare predicate is a 'restrict_anon': red loses its units = 4 row, as with
   'bigU' above. *)
from e in prods group {e.color}
  compute {total = (sumU at {e.units > 5}).eval ()};
> val it = [{color="red",total=10},{color="blue",total=7}]
>   : {color:string, total:int} bag

(*) A 'label: pred' entry is a labeled 'restrict'.
from e in prods group {e.color}
  compute {s = (ctxS at {big: e.units > 5}).eval ()};
> val it =
>   [{color="red",s="{big: e.units > 5, e.color = \"red\"}"},
>    {color="blue",s="{big: e.units > 5, e.color = \"blue\"}"}]
>   : {color:string, s:string} bag

(* 'relax e.field' removes the group-key modifier, so 'whole' is the grand
   total against each group's 'part'. *)
from e in prods
  group {e.color}
  compute {part = sumU.eval (), whole = (sumU at {relax e.color}).eval ()};
> val it = [{color="red",part=14,whole=21},{color="blue",part=7,whole=21}]
>   : {color:string, part:int, whole:int} bag

(* 'e.field = value' is an 'override' - a what-if that makes each group see the
   "blue" rows. *)
from e in prods
  group {e.color}
  compute {ctx = (ctxS at {e.color = "blue"}).eval (),
           blue = (sumU at {e.color = "blue"}).eval ()};
> val it =
>   [{blue=7,color="red",ctx="{e.color = \"blue\"}"},
>    {blue=7,color="blue",ctx="{e.color = \"blue\"}"}]
>   : {blue:int, color:string, ctx:string} bag

(* Entries within one 'at' apply left-to-right, so a later override on the same
   label wins. *)
from e in prods
  group {e.color}
  compute {folded = (ctxS at {e.color = "red", e.color = "green"}).eval ()};
> val it =
>   [{color="red",folded="{e.color = \"green\"}"},
>    {color="blue",folded="{e.color = \"green\"}"}]
>   : {color:string, folded:string} bag

(* 'at' works on a scalar element too - the range variable is referenced
   directly, without a field - so 'sumM' (over the bag [1, 2, 3]) restricted to
   elements > 1 sums 2 + 3 = 5. *)
from e in data group {} compute {total = (sumM at {e > 1}).eval ()};
> val it = [{total=5}] : {total:int} bag

(* An entry that does not reference the query element is an error. *)
from e in data group {} compute {total = (sumM at {1 = 1}).eval ()};
> stdIn:1.52-1.57 Error: 'at' entry must reference the query element, e.g. 'e' or 'e.field'
>   raised at: stdIn:1.52-1.57

(* Filter on an aggregate by reusing an ordinary 'count' measure - one with no
   job- or department-specific logic - and letting the context do the filtering.
   For each job, count that job's employees in departments that have fewer than
   three employees of that job. Grouping by (job, deptno) constrains the context
   to a single department, so 'cnt' counts that department's employees of that
   job; 'where dc < 3' filters on the count, and the outer group sums per job. *)
val emps =
  bag [{deptno = 10, job = "CLERK", name = "A"},
       {deptno = 10, job = "CLERK", name = "B"},
       {deptno = 10, job = "CLERK", name = "C"},
       {deptno = 20, job = "CLERK", name = "D"},
       {deptno = 30, job = "SALES", name = "E"},
       {deptno = 30, job = "SALES", name = "F"},
       {deptno = 10, job = "SALES", name = "G"}];
> val emps =
>   [{deptno=10,job="CLERK",name="A"},{deptno=10,job="CLERK",name="B"},
>    {deptno=10,job="CLERK",name="C"},{deptno=20,job="CLERK",name="D"},
>    {deptno=30,job="SALES",name="E"},{deptno=30,job="SALES",name="F"},
>    {deptno=10,job="SALES",name="G"}]
>   : {deptno:int, job:string, name:string} bag
val cnt =
  Table.measure
    (fn c => from e in emps where Table.test (c, e) compute count over e);
> val cnt = measure
>   : ('a,{deptno:int, job:string, name:string},unit,int) measure
(* CLERK: dept 10 has 3 (excluded), dept 20 has 1 -> 1. SALES: dept 30 has 2,
   dept 10 has 1 -> 3. *)
from e in emps
  group {e.job, e.deptno} compute {dc = cnt.eval ()}
  where dc < 3
  group {job} compute {n = sum over dc};
> val it = [{job="CLERK",n=1},{job="SALES",n=3}] : {job:string, n:int} bag

(*) End measure.smli
