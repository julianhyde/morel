 * Tests for the Range structure.
 *)

(* Range structure *)
Range;
> val it =
>   {contains=fn,continuousSetOf=fn,discreteSetOf=fn,ranges=fn,toBag=fn,toList=fn}
>   : {contains:'a range -> 'a -> bool,
>      continuousSetOf:'b range list -> 'b continuous_set,
>      discreteSetOf:'c range list -> 'c discrete_set,
>      ranges:'d continuous_set -> 'd range list, toBag:'e discrete_set -> 'e bag,
>      toList:'f discrete_set -> 'f list}

(*) Constructors.
POINT 5 : int range;
> val it = POINT 5 : int range

AT_LEAST 3 : int range;
> val it = AT_LEAST 3 : int range

GREATER_THAN 3 : int range;
> val it = GREATER_THAN 3 : int range

AT_MOST 10 : int range;
> val it = AT_MOST 10 : int range

LESS_THAN 10 : int range;
> val it = LESS_THAN 10 : int range

CLOSED (3, 7) : int range;
> val it = CLOSED (3,7) : int range

OPEN (3, 7) : int range;
> val it = OPEN (3,7) : int range

CLOSED_OPEN (3, 7) : int range;
> val it = CLOSED_OPEN (3,7) : int range

OPEN_CLOSED (3, 7) : int range;
> val it = OPEN_CLOSED (3,7) : int range

(*) contains on int ranges: interior, boundary, exterior.
Range.contains (CLOSED (3, 7)) 5;
> val it = true : bool

Range.contains (CLOSED (3, 7)) 3;
> val it = true : bool

Range.contains (CLOSED (3, 7)) 2;
> val it = false : bool

(*) contains with open bounds.
Range.contains (OPEN (3, 7)) 5;
> val it = true : bool

Range.contains (OPEN (3, 7)) 3;
> val it = false : bool

(*) contains with POINT.
Range.contains (POINT 5) 5;
> val it = true : bool

Range.contains (POINT 5) 4;
> val it = false : bool

(*) contains with unbounded ranges.
Range.contains (AT_LEAST 3) 5;
> val it = true : bool

Range.contains (AT_LEAST 3) 2;
> val it = false : bool

Range.contains (AT_MOST 7) 5;
> val it = true : bool

Range.contains (AT_MOST 7) 8;
> val it = false : bool

Range.contains (GREATER_THAN 3) 4;
> val it = true : bool

Range.contains (GREATER_THAN 3) 3;
> val it = false : bool

Range.contains (LESS_THAN 7) 6;
> val it = true : bool

Range.contains (LESS_THAN 7) 7;
> val it = false : bool

(*) Postfix (method) syntax, with explicit outer parens.
(CLOSED (3, 7)).contains 5;
> val it = true : bool

(*) Postfix syntax without outer parens: "CTOR arg.method" parses as
(*) "(CTOR arg).method", not "CTOR (arg.method)".
CLOSED (3, 7).contains 5;
> val it = true : bool

(*) contains on char ranges.
Range.contains (CLOSED (#"a", #"z")) #"e";
> val it = true : bool

Range.contains (CLOSED (#"a", #"z")) #"E";
> val it = false : bool

(*) contains on bool * DESC int ranges (exotic element type).
Range.contains (CLOSED ((false, DESC 5), (false, DESC 3))) (false, DESC 4);
> val it = true : bool

Range.contains (CLOSED ((false, DESC 5), (false, DESC 3))) (false, DESC 6);
> val it = false : bool

(*) continuousSetOf normalizes a list of ranges into a continuous_set.
Range.continuousSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = CONTINUOUS_SET [CLOSED (1,10)] : int continuous_set

(*) Non-overlapping ranges are kept separate.
Range.continuousSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val it = CONTINUOUS_SET [CLOSED (1,3),CLOSED (7,9)] : int continuous_set

(*) discreteSetOf normalizes a list of ranges into a discrete_set.
Range.discreteSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = DISCRETE_SET [CLOSED (1,10)] : int discrete_set

(*) Adjacent discrete ranges are merged: [1,3] and [4,7] become [1,7].
Range.discreteSetOf [CLOSED (1, 3), CLOSED (4, 7)];
> val it = DISCRETE_SET [CLOSED (1,7)] : int discrete_set

(*) discreteSetOf requires a discrete element type; string is not discrete.
Range.discreteSetOf [CLOSED ("a", "z")];
> java.lang.IllegalArgumentException: not a discrete type: string

(*) real is not discrete.
Range.discreteSetOf [CLOSED (1.0, 3.0)];
> java.lang.IllegalArgumentException: not a discrete type: real

(*) A tuple containing a non-discrete component is not discrete.
Range.discreteSetOf [CLOSED ((false, "a"), (true, "z"))];
> java.lang.IllegalArgumentException: not a discrete type: string

(*) contains on continuous_set (postfix syntax).
val cs = Range.continuousSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val cs = CONTINUOUS_SET [CLOSED (1,3),CLOSED (7,9)] : int continuous_set

cs.contains 2;
> val it = true : bool

cs.contains 5;
> val it = false : bool

(*) contains on discrete_set (postfix syntax).
val ds = Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val ds = DISCRETE_SET [CLOSED (1,3),CLOSED (7,9)] : int discrete_set

ds.contains 2;
> val it = true : bool

ds.contains 5;
> val it = false : bool

(*) ranges returns the list of ranges in a continuous_set.
cs.ranges ();
> val it = [CLOSED (1,3),CLOSED (7,9)] : int range list

(*) toList enumerates values of a discrete_set in ascending order.
(Range.discreteSetOf [CLOSED (5, 10)]).toList ();
> val it = [5,6,7,8,9,10] : int list

(Range.discreteSetOf [OPEN (5, 10)]).toList ();
> val it = [6,7,8,9] : int list

(Range.discreteSetOf [POINT 5]).toList ();
> val it = [5] : int list

(Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)]).toList ();
> val it = [1,2,3,7,8,9] : int list

(*) toList on char ranges.
(Range.discreteSetOf [CLOSED (#"a", #"e")]).toList ();
> val it = [#"a",#"b",#"c",#"d",#"e"] : char list

(*) toList on bool * bool (exotic element type).
(Range.discreteSetOf [CLOSED ((false, false), (true, true))]).toList ();
> val it = [(false,false),(false,true),(true,false),(true,true)] : (bool * bool) list

(*) toList on bool * DESC int.
(Range.discreteSetOf [CLOSED ((false, DESC 3), (false, DESC 1))]).toList ();
> val it = [(false,DESC 3),(false,DESC 2),(false,DESC 1)]
>   : (bool * int descending) list

(*) toBag enumerates values as a bag.
(Range.discreteSetOf [CLOSED (1, 3)]).toBag ();
> val it = [1,2,3] : int bag

(*) End range.smli
