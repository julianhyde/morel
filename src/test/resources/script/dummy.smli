fun edge (x, y) =
  (x, y) elem [(1,2),(2,3),(1,4),(4,5),(5,1),(5,6)];
> val edge = fn : int * int -> bool

fun reachable (x, y) =
  edge (x, y) orelse
  exists z where edge (x, z) andalso reachable (z, y);
> val reachable = fn : int * int -> bool

from source in [1,2,3,4,5,6]
  yield {source,
         c = count (from target where reachable (source, target))};
> val it =
>   [{c=6,source=1},{c=1,source=2},{c=0,source=3},{c=6,source=4},{c=6,source=5},
>    {c=0,source=6}] : {c:int, source:int} list

(*) End dummy.smli
