 *
 * Tests for the `Plan` and `Core` structures. *)
Sys.set ("printDepth", 999);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("lineWidth", 120);
> val it = () : unit

(*) Phase 1a, milestone M1: scalar smoke test.

(* `Plan.core e` returns both the runtime value of `e` and a reified
 * `Core.expr` representing its typed Core form. *)

(*) An integer literal reifies to `INT_LITERAL`.
Plan.core 1;
> val it = {expr=INT_LITERAL 1,value=1} : {expr:expr, value:int}

Plan.core 0;
> val it = {expr=INT_LITERAL 0,value=0} : {expr:expr, value:int}

Plan.core ~5;
> val it = {expr=INT_LITERAL ~5,value=~5} : {expr:expr, value:int}

(*) The result is a record; either field can be projected out.
val r = Plan.core 42;
> val r = {expr=INT_LITERAL 42,value=42} : {expr:expr, value:int}

#value r;
> val it = 42 : int

#expr r;
> val it = INT_LITERAL 42 : expr

(* The reified expr is just data; it can be matched on. *)
case #expr (Plan.core 7) of INT_LITERAL n => n | _ => 0;
> val it = 7 : int

(*) Integer addition reifies to a `PLUS` node.
Plan.core (1 + 2);
> val it = {expr=PLUS (INT_LITERAL 1,INT_LITERAL 2,T_INT),value=3}
>   : {expr:expr, value:int}

(*) Both summands are themselves reified.
Plan.core (3 + 4);
> val it = {expr=PLUS (INT_LITERAL 3,INT_LITERAL 4,T_INT),value=7}
>   : {expr:expr, value:int}

(*) Nested addition reifies as nested PLUS.
Plan.core ((1 + 2) + 4);
> val it =
>   {expr=PLUS (PLUS (INT_LITERAL 1,INT_LITERAL 2,T_INT),INT_LITERAL 4,T_INT),
>    value=7} : {expr:expr, value:int}

(*) Other literal kinds reify to their dedicated constructors.
Plan.core 3.14;
> val it = {expr=REAL_LITERAL 3.14,value=3.14} : {expr:expr, value:real}

Plan.core "hello";
> val it = {expr=STRING_LITERAL "hello",value="hello"}
>   : {expr:expr, value:string}

Plan.core #"a";
> val it = {expr=CHAR_LITERAL #"a",value=#"a"} : {expr:expr, value:char}

(* `true` and `false` reify as VAR (they are bindings in the environment,
 * not Op.BOOL_LITERAL nodes); the BOOL_LITERAL constructor handles
 * compiler-synthesized boolean literals (e.g., in `andalso` desugaring). *)
Plan.core true;
> val it = {expr=BOOL_LITERAL true,value=true} : {expr:expr, value:bool}

Plan.core false;
> val it = {expr=BOOL_LITERAL false,value=false} : {expr:expr, value:bool}

(* Unit reifies as UNIT_LITERAL — never as TUPLE [] or E_RECORD ([], _),
 * which would be equivalent but non-canonical. *)
Plan.core ();
> val it = {expr=UNIT_LITERAL,value=()} : {expr:expr, value:unit}

(* An empty `from` is the singleton `[()]` of type `unit list`. It
 * reifies as a LIST_LITERAL with one UNIT_LITERAL. *)
Plan.core (from);
> val it = {expr=LIST_LITERAL ([UNIT_LITERAL],T_LIST T_UNIT),value=[()]} : {expr:expr, value:unit list}

(* A relational query desugars to PROJECT/FILTER over a VAR
 * leaf (emps), with scalar payloads reified as APPLY/FIELD/RECORD. *)
val emps = [{ename="x", deptno=10}];
> val emps = [{deptno=10,ename="x"}] : {deptno:int, ename:string} list
Plan.core (from e in emps where e.deptno elem [10, 20] yield {e.ename, e.deptno});
> val it =
>   {
>    expr=
>    PROJECT (
>     FILTER (SCAN ("e",VAR ("emps",T_LIST (T_RECORD [("deptno",T_INT),("ename",T_STRING)]))),
>      ELEM (
>       FIELD (
>        FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>         T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"deptno",T_INT),
>       LIST_LITERAL ([INT_LITERAL 10,INT_LITERAL 20],T_LIST T_INT))),
>     E_RECORD (
>      [
>       ("deptno",
>        FIELD (
>         FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>          T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"deptno",T_INT)),
>       ("ename",
>        FIELD (
>         FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>          T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"ename",T_STRING))],
>      T_RECORD [("deptno",T_INT),("ename",T_STRING)])),value=[{deptno=10,ename="x"}]}
>   : {expr:expr, value:{deptno:int, ename:string} list}

(*) An empty 'from' is equivalent to [()].
Plan.core (from);
> val it = {expr=LIST_LITERAL ([UNIT_LITERAL],T_LIST T_UNIT),value=[()]} : {expr:expr, value:unit list}

Plan.core (from e in scott.emps where e.job = "CLERK" order (e.deptno, DESC e.sal));
> val it =
>   {
>    expr=
>    ORDER (
>     FILTER (
>      SCAN ("e",
>       FIELD (
>        VAR ("scott",
>         T_RECORD [("bonuses",T_BAG (T_RECORD [("comm",T_REAL),("ename",T_STRING),("job",T_STRING),("sal",T_REAL)])),
>          ("depts",T_BAG (T_RECORD [("deptno",T_INT),("dname",T_STRING),("loc",T_STRING)])),
>          ("emps",
>           T_BAG (T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>            ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])),
>          ("salgrades",T_BAG (T_RECORD [("grade",T_INT),("hisal",T_REAL),("losal",T_REAL)]))]),"emps",
>        T_BAG (T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>         ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]))),
>      EQUALS (
>       FIELD (
>        FIELD (
>         VAR ("$0",
>          T_RECORD [
>           ("e",
>            T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>             ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>         T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>          ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"job",T_STRING),STRING_LITERAL "CLERK")),
>     TUPLE [
>      FIELD (
>       FIELD (
>        VAR ("$0",
>         T_RECORD [
>          ("e",
>           T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>            ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>        T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>         ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"deptno",T_INT),
>      APPLY (VAR ("DESC",T_FN (T_REAL,T_DATA ("descending",[T_REAL]))),
>       FIELD (
>        FIELD (
>         VAR ("$0",
>          T_RECORD [
>           ("e",
>            T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>             ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>         T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>          ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"sal",T_REAL),T_DATA ("descending",[T_REAL]))]),
>    value=
>    [{comm=0,deptno=10,empno=7934,ename="MILLER",hiredate="1982-01-23",job="CLERK",mgr=7782,sal=1300},
>     {comm=0,deptno=20,empno=7876,ename="ADAMS",hiredate="1987-05-23",job="CLERK",mgr=7788,sal=1100},
>     {comm=0,deptno=20,empno=7369,ename="SMITH",hiredate="1980-12-17",job="CLERK",mgr=7902,sal=800},
>     {comm=0,deptno=30,empno=7900,ename="JAMES",hiredate="1981-12-03",job="CLERK",mgr=7698,sal=950}]}
>   : {expr:expr,
>      value:{comm:real, deptno:int, empno:int, ename:string, hiredate:string, job:string, mgr:int, sal:real} list}

(* Closure-capture: a lambda built via Plan.core captures the
 * values of free variables in its lexical environment, just like an
 * ordinary closure. The reified `expr` reflects those captured
 * values (the Inliner replaces VAR "n" with its bound value at the
 * time of Plan.core), and the runtime `value` is a closure that
 * does NOT see later re-bindings of `n`. *)
val n = 10;
> val n = 10 : int
val r = Plan.core (fn x => x + n);
> val r = {expr=FN (P_VAR ("x",T_INT),PLUS (VAR ("x",T_INT),INT_LITERAL 10,T_INT),T_FN (T_INT,T_INT)),value=fn}
>   : {expr:expr, value:int -> int}
#value r 5;
> val it = 15 : int
(* Shadow n with a new top-level binding. The closure still uses
 * the captured value of 10, so the result remains 15. *)
val n = 100;
> val n = 100 : int
#value r 5;
> val it = 15 : int

(* CASE under a lambda is not constant-folded; its match patterns
 * reify via the pat datatype's per-kind P_*_LIT and P_WILD
 * constructors, and the binder reifies as P_VAR. *)
Plan.core (fn n => case n of 0 => "z" | _ => "nz");
> val it =
>   {
>    expr=
>    FN (P_VAR ("n",T_INT),
>     CASE (VAR ("n",T_INT),[(P_INT_LIT 0,STRING_LITERAL "z"),(P_WILD T_INT,STRING_LITERAL "nz")],T_STRING),
>     T_FN (T_INT,T_STRING)),value=fn} : {expr:expr, value:int -> string}

(* Plan.transform applies a Core.expr -> Core.expr rewriter to the
 * reified expression and recompiles. With the identity rewriter, the
 * expression and value round-trip unchanged. *)
val id = fn x : expr => x;
> val id = fn : expr -> expr

(*) Identity transform on an int literal.
Plan.transform (Plan.core 42, id);
> val it = {expr=INT_LITERAL 42,value=42} : {expr:expr, value:int}

(*) Identity transform on a string literal.
Plan.transform (Plan.core "hi", id);
> val it = {expr=STRING_LITERAL "hi",value="hi"} : {expr:expr, value:string}

(*) Identity transform on a unit literal.
Plan.transform (Plan.core (), id);
> val it = {expr=UNIT_LITERAL,value=()} : {expr:expr, value:unit}

(* Identity transform on an arithmetic expression: round-trips through
 * APPLY of `op +` over a TUPLE. *)
Plan.transform (Plan.core (1 + 2), id);
> val it = {expr=PLUS (INT_LITERAL 1,INT_LITERAL 2,T_INT),value=3}
>   : {expr:expr, value:int}

(* Identity transform on an FN: introduces a P_VAR binding seen by
 * the body's VAR reference. *)
val r = Plan.transform (Plan.core (fn x => x + 1), id);
> val r =
>   {expr=FN (P_VAR ("x",T_INT),PLUS (VAR ("x",T_INT),INT_LITERAL 1,T_INT),T_FN (T_INT,T_INT)),value=fn}
>   : {expr:expr, value:int -> int}
#value r 41;
> val it = 42 : int

(*) Identity transform on a record: round-trips through E_RECORD.
Plan.transform (Plan.core {a = 1, b = "x"}, id);
> val it =
>   {
>    expr=
>    E_RECORD ([("a",INT_LITERAL 1),("b",STRING_LITERAL "x")],T_RECORD [("a",T_INT),("b",T_STRING)]),
>    value={a=1,b="x"}} : {expr:expr, value:{a:int, b:string}}

(*) Identity transform on a record-field selection: round-trips through FIELD.
Plan.transform (Plan.core (#a {a = 99, b = "x"}), id);
> val it =
>   {
>    expr=
>    FIELD (
>     E_RECORD ([("a",INT_LITERAL 99),("b",STRING_LITERAL "x")],T_RECORD [("a",T_INT),("b",T_STRING)]),
>     "a",T_INT),value=99} : {expr:expr, value:int}

(* -------------------------------------------------------------------
 * Identity transform on relational chains: round-trip through
 * FromBuilder. *)

(*) Empty `from` (the unit-list literal).
Plan.transform (Plan.core (from), id);
> val it = {expr=LIST_LITERAL ([UNIT_LITERAL],T_LIST T_UNIT),value=[()]} : {expr:expr, value:unit list}

(*) Simple scan over a list literal.
Plan.transform (Plan.core (from e in [1,2,3]), id);
> val it = {expr=LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT),value=[1,2,3]}
>   : {expr:expr, value:int list}

(*) Scan + where: round-trips through FILTER.
Plan.transform (Plan.core (from e in [1,2,3] where e > 1), id);
> val it =
>   {
>    expr=
>    FILTER (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT)),
>     GT (FIELD (VAR ("$0",T_RECORD [("e",T_INT)]),"e",T_INT),INT_LITERAL 1)),value=[2,3]} : {expr:expr, value:int list}

(*) Scan + yield: round-trips through PROJECT.
Plan.transform (Plan.core (from e in [1,2,3] yield e + 10), id);
> val it =
>   {
>    expr=
>    PROJECT (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT)),
>     PLUS (FIELD (VAR ("$0",T_RECORD [("e",T_INT)]),"e",T_INT),INT_LITERAL 10,T_INT)),value=[11,12,13]}
>   : {expr:expr, value:int list}

(*) Scan + take/skip: round-trips through SKIP and TAKE.
Plan.transform (Plan.core (from e in [10,20,30,40,50] skip 1 take 2), id);
> val it =
>   {
>    expr=
>    TAKE (
>     SKIP (
>      SCAN ("e",LIST_LITERAL ([INT_LITERAL 10,INT_LITERAL 20,INT_LITERAL 30,INT_LITERAL 40,INT_LITERAL 50],T_LIST T_INT)),
>      INT_LITERAL 1),INT_LITERAL 2),value=[20,30]} : {expr:expr, value:int list}

(* Scan + order: round-trips through ORDER. The descending-by expression
 * goes through DESC ... value, reified as APPLY of DESC. *)
Plan.transform (Plan.core (from e in [3,1,2] order e), id);
> val it =
>   {
>    expr=
>    ORDER (SCAN ("e",LIST_LITERAL ([INT_LITERAL 3,INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT)),
>     FIELD (VAR ("$0",T_RECORD [("e",T_INT)]),"e",T_INT)),value=[1,2,3]} : {expr:expr, value:int list}

(* Complex query against scott.emps with FILTER + ORDER (incl. DESC
 * applied to a real field). Identity round-trip recompiles the chain
 * and re-runs the query — the value is recomputed. *)
val q =
  Plan.transform
    (Plan.core
       (from e in scott.emps
          where e.job = "CLERK"
          order (e.deptno, DESC e.sal)),
     id);
> val q =
>   {
>    expr=
>    ORDER (
>     FILTER (
>      SCAN ("e",
>       FIELD (
>        VAR ("scott",
>         T_RECORD [("bonuses",T_BAG (T_RECORD [("comm",T_REAL),("ename",T_STRING),("job",T_STRING),("sal",T_REAL)])),
>          ("depts",T_BAG (T_RECORD [("deptno",T_INT),("dname",T_STRING),("loc",T_STRING)])),
>          ("emps",
>           T_BAG (T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>            ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])),
>          ("salgrades",T_BAG (T_RECORD [("grade",T_INT),("hisal",T_REAL),("losal",T_REAL)]))]),"emps",
>        T_BAG (T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>         ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]))),
>      EQUALS (
>       FIELD (
>        FIELD (
>         VAR ("$0",
>          T_RECORD [
>           ("e",
>            T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>             ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>         T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>          ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"job",T_STRING),STRING_LITERAL "CLERK")),
>     TUPLE [
>      FIELD (
>       FIELD (
>        VAR ("$0",
>         T_RECORD [
>          ("e",
>           T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>            ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>        T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>         ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"deptno",T_INT),
>      APPLY (VAR ("DESC",T_FN (T_REAL,T_DATA ("descending",[T_REAL]))),
>       FIELD (
>        FIELD (
>         VAR ("$0",
>          T_RECORD [
>           ("e",
>            T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>             ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)])]),"e",
>         T_RECORD [("comm",T_REAL),("deptno",T_INT),("empno",T_INT),("ename",T_STRING),("hiredate",T_STRING),
>          ("job",T_STRING),("mgr",T_INT),("sal",T_REAL)]),"sal",T_REAL),T_DATA ("descending",[T_REAL]))]),
>    value=
>    [{comm=0,deptno=10,empno=7934,ename="MILLER",hiredate="1982-01-23",job="CLERK",mgr=7782,sal=1300},
>     {comm=0,deptno=20,empno=7876,ename="ADAMS",hiredate="1987-05-23",job="CLERK",mgr=7788,sal=1100},
>     {comm=0,deptno=20,empno=7369,ename="SMITH",hiredate="1980-12-17",job="CLERK",mgr=7902,sal=800},
>     {comm=0,deptno=30,empno=7900,ename="JAMES",hiredate="1981-12-03",job="CLERK",mgr=7698,sal=950}]}
>   : {expr:expr,
>      value:{comm:real, deptno:int, empno:int, ename:string, hiredate:string, job:string, mgr:int, sal:real} list}

(*) Where + yield chain over a record-typed list.
val r =
  Plan.transform
    (Plan.core (from e in emps where e.deptno elem [10] yield {e.ename, e.deptno}),
     id);
> val r =
>   {
>    expr=
>    PROJECT (
>     FILTER (SCAN ("e",VAR ("emps",T_LIST (T_RECORD [("deptno",T_INT),("ename",T_STRING)]))),
>      ELEM (
>       FIELD (
>        FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>         T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"deptno",T_INT),LIST_LITERAL ([INT_LITERAL 10],T_LIST T_INT))),
>     E_RECORD (
>      [
>       ("deptno",
>        FIELD (
>         FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>          T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"deptno",T_INT)),
>       ("ename",
>        FIELD (
>         FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("deptno",T_INT),("ename",T_STRING)])]),"e",
>          T_RECORD [("deptno",T_INT),("ename",T_STRING)]),"ename",T_STRING))],
>      T_RECORD [("deptno",T_INT),("ename",T_STRING)])),value=[{deptno=10,ename="x"}]}
>   : {expr:expr, value:{deptno:int, ename:string} list}

(* Multi-scan: reifies as JOIN. Element types of e (int) and d (string)
 * differ, so JOIN's scan-variable matching is unambiguous. *)
Plan.transform (Plan.core (from e in [1,2], d in ["a","b"]), id);
> val it =
>   {
>    expr=
>    JOIN (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT)),
>     SCAN ("d",LIST_LITERAL ([STRING_LITERAL "a",STRING_LITERAL "b"],T_LIST T_STRING)),BOOL_LITERAL true),
>    value=[{d="a",e=1},{d="b",e=1},{d="a",e=2},{d="b",e=2}]} : {expr:expr, value:{d:string, e:int} list}

(* GROUP with an aggregate that has an argument. Reified aggregates
 * carry an `expr option` for the argument: `["SOME", arg_expr]` when
 * the aggregate computes per-row (e.g. `sum over e.v`), `["NONE"]`
 * otherwise. The aggregate function itself reifies as a desugared
 * closure: the `sum over X` form becomes `fn $col => sum:int (fromList $col)`. *)
val grouped =
  Plan.transform
    (Plan.core
       (from e in [{k=1,v=10},{k=1,v=20},{k=2,v=30}]
          group e.k compute {s = sum over e.v}),
     id);
> val grouped =
>   {
>    expr=
>    GROUP (
>     SCAN ("e",
>      LIST_LITERAL (
>       [E_RECORD ([("k",INT_LITERAL 1),("v",INT_LITERAL 10)],T_RECORD [("k",T_INT),("v",T_INT)]),
>        E_RECORD ([("k",INT_LITERAL 1),("v",INT_LITERAL 20)],T_RECORD [("k",T_INT),("v",T_INT)]),
>        E_RECORD ([("k",INT_LITERAL 2),("v",INT_LITERAL 30)],T_RECORD [("k",T_INT),("v",T_INT)])],
>       T_LIST (T_RECORD [("k",T_INT),("v",T_INT)]))),
>     [
>      ("k",
>       FIELD (
>        FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("k",T_INT),("v",T_INT)])]),"e",T_RECORD [("k",T_INT),("v",T_INT)]),"k",
>        T_INT))],
>     [
>      ("s",
>       FN (P_VAR ("$col",T_LIST T_INT),
>        APPLY (VAR ("sum:int",T_FN (T_TUPLE [T_INT,T_INT],T_INT)),
>         APPLY (VAR ("fromList",T_FN (T_LIST (T_VAR 0),T_BAG (T_VAR 0))),VAR ("$col",T_LIST T_INT),T_BAG T_INT),T_INT),
>        T_FN (T_LIST T_INT,T_INT)),
>       SOME (FIELD (
>        FIELD (VAR ("$0",T_RECORD [("e",T_RECORD [("k",T_INT),("v",T_INT)])]),"e",T_RECORD [("k",T_INT),("v",T_INT)]),"v",
>        T_INT)))]),value=[{k=1,s=30},{k=2,s=30}]} : {expr:expr, value:{k:int, s:int} list}

(*) Scan + union: combines lists.
Plan.transform (Plan.core (from e in [1,2] union [3,4]), id);
> val it =
>   {
>    expr=
>    UNION (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT)),false,
>     [LIST_LITERAL ([INT_LITERAL 3,INT_LITERAL 4],T_LIST T_INT)]),value=[1,2,3,4]} : {expr:expr, value:int list}

(* Identity transform on a RAISE inside a lambda (so the value can be
 * reified without evaluating the raise). Round-trips through RAISE. *)
val divZero = Plan.transform (Plan.core ((fn () => raise Empty) : unit -> int), id);
> val divZero = {expr=FN (P_VAR ("v",T_UNIT),RAISE (VAR ("Empty",T_DATA ("exn",[])),T_INT),T_FN (T_UNIT,T_INT)),value=fn}
>   : {expr:expr, value:unit -> int}

(* -------------------------------------------------------------------
 * Closure-capture under Plan.transform: Plan.core captures the value
 * of a free variable at the moment of reify (here, k = 7). The
 * captured constant becomes INT_LITERAL 7 inside the reified expr,
 * so rebinding `k` either before OR after the Plan.transform call
 * has no effect on the recompiled closure. *)
val k = 7;
> val k = 7 : int
val plannedK = Plan.core (fn x => x + k);
> val plannedK =
>   {expr=FN (P_VAR ("x",T_INT),PLUS (VAR ("x",T_INT),INT_LITERAL 7,T_INT),T_FN (T_INT,T_INT)),value=fn}
>   : {expr:expr, value:int -> int}

(* Rebind k BEFORE the transform; the captured 7 is already baked
 * into plannedK.expr, so the transform reproduces a closure of x+7. *)
val k = 50;
> val k = 50 : int
val rk = Plan.transform (plannedK, id);
> val rk =
>   {expr=FN (P_VAR ("x",T_INT),PLUS (VAR ("x",T_INT),INT_LITERAL 7,T_INT),T_FN (T_INT,T_INT)),value=fn}
>   : {expr:expr, value:int -> int}
#value rk 100;
> val it = 107 : int

(* Rebinding k AFTER the transform also leaves rk unchanged. *)
val k = 99;
> val k = 99 : int
#value rk 100;
> val it = 107 : int

(* -------------------------------------------------------------------
 * Similar to previous but we use a non-atomic value, and we use it twice,
 * to prevent it from being inlined. The Inliner replaces each occurrence
 * of `k` with a VALUE_LITERAL carrying the runtime list [1,2]; reify
 * unpacks it into a LIST_LITERAL of INT_LITERALs, so the captured value
 * survives a transform/optimize round-trip. *)
val k = [1,2];
> val k = [1,2] : int list
val plannedK = Plan.core (fn x => x + k.length() + k.length());
> val plannedK =
>   {
>    expr=
>    FN (P_VAR ("x",T_INT),
>     PLUS (
>      PLUS (VAR ("x",T_INT),
>       APPLY (VAR ("length",T_FN (T_LIST T_INT,T_INT)),LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT),T_INT),
>       T_INT),
>      APPLY (VAR ("length",T_FN (T_LIST T_INT,T_INT)),LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT),T_INT),
>      T_INT),T_FN (T_INT,T_INT)),value=fn} : {expr:expr, value:int -> int}
#value plannedK 100;
> val it = 104 : int

(* Rewrite plannedK with a non-identity rule that swaps the operands of
 * every PLUS. Since `+` is commutative on ints the recomputed value is
 * unchanged, but the rewritten expr makes the swap visible. *)
fun swapPlus (PLUS (a, b, t)) = SOME (PLUS (b, a, t))
  | swapPlus _ = NONE;
> val swapPlus = fn : expr -> expr option
val k = [1,2,3];
> val k = [1,2,3] : int list
val rk = Plan.optimize (plannedK, [swapPlus]);
> val rk =
>   {
>    expr=
>    FN (P_VAR ("x",T_INT),
>     PLUS (
>      APPLY (VAR ("length",T_FN (T_LIST T_INT,T_INT)),LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT),T_INT),
>      PLUS (
>       APPLY (VAR ("length",T_FN (T_LIST T_INT,T_INT)),LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT),T_INT),
>       VAR ("x",T_INT),T_INT),T_INT),T_FN (T_INT,T_INT)),value=fn} : {expr:expr, value:int -> int}
#value rk 100;
> val it = 104 : int

val k = [1,2,3,4];
> val k = [1,2,3,4] : int list
#value rk 100;
> val it = 104 : int
#value rk 101;
> val it = 105 : int

(*) Identity transform on a CASE: introduces P_INT_LIT / P_WILD branches.
val classify = Plan.transform (Plan.core (fn n => case n of 0 => "z" | _ => "nz"), id);
> val classify =
>   {
>    expr=
>    FN (P_VAR ("n",T_INT),
>     CASE (VAR ("n",T_INT),[(P_INT_LIT 0,STRING_LITERAL "z"),(P_WILD T_INT,STRING_LITERAL "nz")],T_STRING),
>     T_FN (T_INT,T_STRING)),value=fn} : {expr:expr, value:int -> string}
(#value classify) 0;
> val it = "z" : string
(#value classify) 5;
> val it = "nz" : string

(* Operator round-trips: each Morel operator reifies as a dedicated
 * Core.expr constructor (MINUS, TIMES, EQUALS, LT, AND, NOT, etc.)
 * rather than as a generic APPLY of `op X`. Identity transform
 * preserves the shape and re-evaluates to the same value. *)

(* Arithmetic: subtraction, multiplication, real division, int division,
 * modulo, negation. *)
Plan.transform (Plan.core (10 - 3), id);
> val it = {expr=MINUS (INT_LITERAL 10,INT_LITERAL 3,T_INT),value=7} : {expr:expr, value:int}

Plan.transform (Plan.core (4 * 5), id);
> val it = {expr=TIMES (INT_LITERAL 4,INT_LITERAL 5,T_INT),value=20} : {expr:expr, value:int}

Plan.transform (Plan.core (7 div 2), id);
> val it = {expr=DIV (INT_LITERAL 7,INT_LITERAL 2,T_INT),value=3} : {expr:expr, value:int}

Plan.transform (Plan.core (7 mod 3), id);
> val it = {expr=MOD (INT_LITERAL 7,INT_LITERAL 3,T_INT),value=1} : {expr:expr, value:int}

(*) Comparisons.
Plan.transform (Plan.core (1 = 1), id);
> val it = {expr=EQUALS (INT_LITERAL 1,INT_LITERAL 1),value=true} : {expr:expr, value:bool}

Plan.transform (Plan.core (1 <> 2), id);
> val it = {expr=NOT_EQUALS (INT_LITERAL 1,INT_LITERAL 2),value=true} : {expr:expr, value:bool}

Plan.transform (Plan.core (3 < 4), id);
> val it = {expr=LT (INT_LITERAL 3,INT_LITERAL 4),value=true} : {expr:expr, value:bool}

Plan.transform (Plan.core (3 <= 4), id);
> val it = {expr=LE (INT_LITERAL 3,INT_LITERAL 4),value=true} : {expr:expr, value:bool}

Plan.transform (Plan.core (3 > 4), id);
> val it = {expr=GT (INT_LITERAL 3,INT_LITERAL 4),value=false} : {expr:expr, value:bool}

Plan.transform (Plan.core (3 >= 4), id);
> val it = {expr=GE (INT_LITERAL 3,INT_LITERAL 4),value=false} : {expr:expr, value:bool}

(*) String concatenation, list cons and append.
Plan.transform (Plan.core ("a" ^ "b"), id);
> val it = {expr=CONCAT (STRING_LITERAL "a",STRING_LITERAL "b"),value="ab"} : {expr:expr, value:string}

Plan.transform (Plan.core (1 :: [2,3]), id);
> val it =
>   {expr=CONS (INT_LITERAL 1,LIST_LITERAL ([INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT),T_LIST T_INT),value=[1,2,3]}
>   : {expr:expr, value:int list}

Plan.transform (Plan.core ([1,2] @ [3,4]), id);
> val it =
>   {
>    expr=
>    AT (LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT),
>     LIST_LITERAL ([INT_LITERAL 3,INT_LITERAL 4],T_LIST T_INT),T_LIST T_INT),value=[1,2,3,4]}
>   : {expr:expr, value:int list}

(*) ELEM / NOT_ELEM membership tests.
Plan.transform (Plan.core (1 elem [1,2,3]), id);
> val it =
>   {expr=ELEM (INT_LITERAL 1,LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT)),value=true}
>   : {expr:expr, value:bool}

(* Boolean operators: n-ary AND/OR flatten chains of andalso/orelse.
 * Note: `true` and `false` reify as `VAR` (they're env-bound
 * constructors, not synthesized BOOL_LITERAL nodes). *)
Plan.transform (Plan.core (true andalso false andalso true), id);
> val it = {expr=AND [BOOL_LITERAL true,BOOL_LITERAL false,BOOL_LITERAL true],value=false} : {expr:expr, value:bool}

Plan.transform (Plan.core (false orelse true orelse false), id);
> val it = {expr=OR [BOOL_LITERAL false,BOOL_LITERAL true,BOOL_LITERAL false],value=true} : {expr:expr, value:bool}

Plan.transform (Plan.core (not false), id);
> val it = {expr=NOT (BOOL_LITERAL false),value=true} : {expr:expr, value:bool}

(*) Unary negation.
Plan.transform (Plan.core (~5), id);
> val it = {expr=INT_LITERAL ~5,value=~5} : {expr:expr, value:int}

(* Plan.transform checks that the rewriter is type-preserving. If the
 * rewriter returns a Core.expr of a different Morel type than the
 * original, Plan.transform raises a runtime error rather than
 * silently producing a wrongly-typed value. *)
Plan.transform (Plan.core 1, fn _ => STRING_LITERAL "wrong");
> uncaught exception Fail [Fail: Plan.transform: rewriter changed expression type from int to string]
>   raised at: 0.0-0.0

(* Plan.expr_type returns the reified Type.t of a reified Core.expr.
 * It walks the top-level constructor: most cases read an embedded
 * type out of the payload, a few (TUPLE, LET, FROM-step chains)
 * recurse, and JOIN/GROUP fall back to a full unreify because their
 * element-type depends on scan-variable names not in the reified
 * form. Plan.transform uses it on both old and new expressions to
 * verify that the rewriter is type-preserving.
 *)

Plan.expr_type (INT_LITERAL 1);
> val it = T_INT : t

Plan.expr_type (#expr (Plan.core (1 + 2)));
> val it = T_INT : t

Plan.expr_type (#expr (Plan.core (1 = 2)));
> val it = T_BOOL : t

Plan.expr_type (#expr (Plan.core "x"));
> val it = T_STRING : t

Plan.expr_type (#expr (Plan.core (fn x => x + 1)));
> val it = T_FN (T_INT,T_INT) : t

Plan.expr_type (#expr (Plan.core (1, "a")));
> val it = T_TUPLE [T_INT,T_STRING] : t

Plan.expr_type (#expr (Plan.core (from e in [1,2,3] where e > 1)));
> val it = T_LIST (T_RECORD [("e",T_INT)]) : t

(* Plan.optimize applies a list of rules (each Core.expr -> Core.expr
 * option) bottom-up to a planned value's reified expression, firing
 * each rule at most once per node. The transformed expression is then
 * recompiled in the session's environment. *)

(* Rule: merge two consecutive FILTERs into a single FILTER whose
 * condition is the n-ary AND of the two. *)
fun mergeFilters (FILTER (FILTER (input, c1), c2)) =
    SOME (FILTER (input, AND [c1, c2]))
  | mergeFilters _ = NONE;
> val mergeFilters = fn : expr -> expr option

(* Apply the rule to a from-expression with two `where` clauses. The
 * reified form is FILTER(FILTER(source, c1), c2); the rule rewrites
 * it to FILTER(source, AND [c1, c2]). The value is recomputed and
 * remains [2]. *)
Plan.optimize
  (Plan.core (from e in [1,2,3] where e > 1 where e < 3),
   [mergeFilters]);
> val it =
>   {
>    expr=
>    FILTER (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT)),
>     AND [GT (FIELD (VAR ("$0",T_RECORD [("e",T_INT)]),"e",T_INT),INT_LITERAL 1),
>      LT (FIELD (VAR ("$0",T_RECORD [("e",T_INT)]),"e",T_INT),INT_LITERAL 3)]),value=[2]} : {expr:expr, value:int list}

(* Plan.row_type returns the column list of a pipeline expression as
 * SOME [(name, type), ...] in pipeline (positional) order; for
 * non-pipeline expressions it returns NONE. *)

(*) Single-scan chain: SCAN provides the column name.
Plan.row_type (#expr (Plan.core (from e in [1,2,3] where e > 1)));
> val it = SOME [("e",T_INT)] : (string * t) list option

(*) Two-scan join: cols come left-then-right.
Plan.row_type (#expr (Plan.core (from e in [1,2], d in ["a","b"])));
> val it = SOME [("e",T_INT),("d",T_STRING)] : (string * t) list option

(*) Three-scan join: outer JOIN concatenates a 2-col left with 1-col right.
Plan.row_type (#expr (Plan.core (from e in [1,2], d in ["a"], f in [3.0])));
> val it = SOME [("e",T_INT),("d",T_STRING),("f",T_REAL)] : (string * t) list option

(*) Scan elements are records: each scan still contributes one column
(*) named for its scan variable; the column type is the scan element.
Plan.row_type
  (#expr (Plan.core (from e in [{a=1,b=2}], d in [{c=3}])));
> val it = SOME [("e",T_RECORD [("a",T_INT),("b",T_INT)]),("d",T_RECORD [("c",T_INT)])] : (string * t) list option

(*) FILTER, ORDER, etc. are transparent: rowType passes through.
Plan.row_type (#expr (Plan.core (from e in [3,1,2] order e)));
> val it = SOME [("e",T_INT)] : (string * t) list option

(*) PROJECT with a record yield: columns are the record fields.
Plan.row_type (#expr (Plan.core (from e in [{x=1,y=2}] yield {a = e.x + e.y})));
> val it = SOME [("a",T_INT)] : (string * t) list option

(* Destructuring scan: a non-IdPat scan reifies as SCAN("$N", source)
 * wrapped in PROJECT, so the destructured bindings flow downstream
 * by name and appear in rowType in alphabetical order.
 * Wildcards (`_`) contribute no column. *)
Plan.row_type
  (#expr (Plan.core (from (x, _, y) in [(1,2,3)], d in [10,20])));
> val it = SOME [("x",T_INT),("y",T_INT),("d",T_INT)] : (string * t) list option

(*) Record-pattern scan.
Plan.row_type
  (#expr (Plan.core (from {a, b} in [{a=1,b=2}], d in [10])));
> val it = SOME [("a",T_INT),("b",T_INT),("d",T_INT)] : (string * t) list option

(*) NONE — not a pipeline expression.
Plan.row_type (INT_LITERAL 5);
> val it = NONE : (string * t) list option
Plan.row_type (#expr (Plan.core (1 + 2)));
> val it = NONE : (string * t) list option
Plan.row_type (#expr (Plan.core "hi"));
> val it = NONE : (string * t) list option
Plan.row_type (LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2],T_LIST T_INT));
> val it = NONE : (string * t) list option

(* Optimization: push a FILTER through a JOIN onto the LEFT input.
 * The rule fires when its predicate references only columns from
 * the left side; here the predicate `e > 1` mentions `e` only, so
 * the filter is pushed into the left scan. The recomputed value is
 * unchanged. *)
fun pushFilterLeft (FILTER (JOIN (l, r, c), p)) =
    SOME (JOIN (FILTER (l, p), r, c))
  | pushFilterLeft _ = NONE;
> val pushFilterLeft = fn : expr -> expr option

Plan.optimize
  (Plan.core (from e in [1,2,3], d in ["a","b"] where e > 1),
   [pushFilterLeft]);
> val it =
>   {
>    expr=
>    JOIN (
>     FILTER (SCAN ("e",LIST_LITERAL ([INT_LITERAL 1,INT_LITERAL 2,INT_LITERAL 3],T_LIST T_INT)),
>      GT (FIELD (VAR ("$0",T_RECORD [("e",T_INT),("d",T_STRING)]),"e",T_INT),INT_LITERAL 1)),
>     SCAN ("d",LIST_LITERAL ([STRING_LITERAL "a",STRING_LITERAL "b"],T_LIST T_STRING)),BOOL_LITERAL true),
>    value=[{d="a",e=2},{d="b",e=2},{d="a",e=3},{d="b",e=3}]} : {expr:expr, value:{d:string, e:int} list}

(*) End plan.smli
