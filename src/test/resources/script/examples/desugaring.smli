 *
 * Query desugaring and the core operators
 * =======================================
 *
 * Morel's query language is large: 'from' with multiple scans,
 * 'where', 'group', 'compute', 'distinct', 'order', 'union',
 * 'intersect', 'except', 'unorder', and so on. But its meaning can be
 * explained in terms of a small set of "core" operators. Every other
 * construct is "sugar" that desugars into a combination of core
 * operators.
 *
 * This script names each desugaring rule (for example,
 * 'distinct -> coreGroup') and, for each, gives two queries that
 * produce the same result: the first written with sugar, the second
 * written using only the operators it desugars to. Running both and
 * seeing identical output is a check that the rule holds.
 *
 * The core operators are:
 *
 *   - 'fromUnit', the empty pipeline 'from', a collection of one
 *     zero-field element, where every query starts;
 *   - 'join1', add one scan 'pat in exp [on cond]' to a pipeline;
 *   - 'yield', map each element to a new value;
 *   - 'order', sort the elements;
 *   - 'coreGroup', gather elements that share a key, without applying
 *     any aggregate function;
 *   - 'union1', concatenate one more collection;
 *   - 'except1', remove the elements of one more collection;
 *   - 'enumerate', pair each element with its ordinal.
 *
 * Some of these operators ('coreGroup', 'join1', 'union1', 'except1',
 * 'enumerate') have no surface syntax of their own; where that is so,
 * the "core" query below expresses them using the nearest primitive
 * that does. A final section covers the primitive operators -- those,
 * such as 'order', 'skip'/'take' and the outer joins, that have no
 * simpler form.
 *
 * The examples draw on the 'scott' database -- 'scott.emps' and
 * 'scott.depts' -- and, where order or duplicates matter, on small
 * inline lists.
 *)

useSilently "../scott.smli";
> [opening ../scott.smli]
> val it = () : unit

set ("output", "tabular");
> val it = () : unit

(* ---------------------------------------------------------------- *)
(* The core operators                                               *)
(* ---------------------------------------------------------------- *)

(*) 'fromUnit' is the empty 'from': one zero-field element.
from;
> val it = [()] : unit list

(*) 'join1' adds a scan, pairing each existing row with each element of
(*) the new collection (a Cartesian product).
from i in [1, 2], j in [3, 4];
> i j
> - -
> 1 3
> 1 4
> 2 3
> 2 4
>
> val it : {i:int, j:int} list

(*) 'yield' maps each element to a new value.
from d in scott.depts yield d.dname;
> val it = ["ACCOUNTING","RESEARCH","SALES","OPERATIONS"] : string bag

(*) 'order' sorts the elements.
from d in scott.depts order DESC d.deptno;
> deptno dname      loc
> ------ ---------- --------
>     40 OPERATIONS BOSTON
>     30 SALES      CHICAGO
>     20 RESEARCH   DALLAS
>     10 ACCOUNTING NEW YORK
>
> val it : {deptno:int, dname:string, loc:string} list

(*) 'coreGroup' gathers the elements that share a key into a group,
(*) without applying any aggregate. Morel has no 'coreGroup' keyword, so
(*) we use 'group k compute {elements}', which pairs each key with its
(*) elements.
from i in [1, 2, 3, 4] group {even = i mod 2 = 0} compute {elements};
> elements even
> -------- -----
>        1 false
>        3
>        2 true
>        4
>
> val it : {`elements`:int list, even:bool} list

(*) 'union1' concatenates one more collection (SQL 'UNION ALL').
from i in [1, 2] union [2, 3];
> val it = [1,2,2,3] : int list

(*) 'except1' removes the elements of one more collection (SQL
(*) 'EXCEPT ALL': one element removed per match).
from i in [1, 2, 2, 3] except [2];
> val it = [1,2,3] : int list

(*) 'enumerate' pairs each element with its ordinal. It has no surface
(*) syntax; see the 'ordinal' note near the end.

(* ---------------------------------------------------------------- *)
(* Desugaring rules (fundamental concepts first)                    *)
(* ---------------------------------------------------------------- *)

(* from -> fromUnit join1
   A 'from' with one scan is 'fromUnit' (the one-element pipeline '[()]')
   followed by a 'join1' that adds the scan (then a 'yield' to drop the
   unit). *)
from d in scott.depts;
> deptno dname      loc
> ------ ---------- --------
>     10 ACCOUNTING NEW YORK
>     20 RESEARCH   DALLAS
>     30 SALES      CHICAGO
>     40 OPERATIONS BOSTON
>
> val it : {deptno:int, dname:string, loc:string} bag
from u in [()], d in scott.depts yield d;
> deptno dname      loc
> ------ ---------- --------
>     10 ACCOUNTING NEW YORK
>     20 RESEARCH   DALLAS
>     30 SALES      CHICAGO
>     40 OPERATIONS BOSTON
>
> val it : {deptno:int, dname:string, loc:string} bag

(* scan p = exp -> scan p in [exp]
   A scan that binds a variable to a single value is a scan over the
   one-element list '[exp]'. 'exp' may depend on earlier scans. *)
from d in scott.depts, hi = d.deptno + 1;
> d                          hi
> deptno dname      loc
> ------ ---------- -------- --
>     10 ACCOUNTING NEW YORK 11
>     20 RESEARCH   DALLAS   21
>     30 SALES      CHICAGO  31
>     40 OPERATIONS BOSTON   41
>
> val it : {d:{deptno:int, dname:string, loc:string}, hi:int} bag
from d in scott.depts, hi in [d.deptno + 1];
> d                          hi
> deptno dname      loc
> ------ ---------- -------- --
>     10 ACCOUNTING NEW YORK 11
>     20 RESEARCH   DALLAS   21
>     30 SALES      CHICAGO  31
>     40 OPERATIONS BOSTON   41
>
> val it : {d:{deptno:int, dname:string, loc:string}, hi:int} bag

(* scan {f1, f2 = const, ...} in t -> where yield
   A record pattern splits in two: a field matched against a constant
   becomes a 'where', a field bound to a variable becomes a 'yield'. *)
from {deptno = 10, ename, ...} in scott.emps;
> val it = ["CLARK","KING","MILLER"] : string bag
from e in scott.emps where e.deptno = 10 yield e.ename;
> val it = ["CLARK","KING","MILLER"] : string bag

(* join -> join1 ...
   A 'from' with several scans is one 'join1' per scan; an 'on' condition
   rides with its scan. The comma and the 'join' keyword are the same.
   (Projected with 'yield', since the joined records are wide.) *)
from d in scott.depts, e in scott.emps on d.deptno = e.deptno
  yield {d.dname, e.ename};
> dname      ename
> ---------- ------
> ACCOUNTING CLARK
> ACCOUNTING KING
> ACCOUNTING MILLER
> RESEARCH   SMITH
> RESEARCH   JONES
> RESEARCH   SCOTT
> RESEARCH   ADAMS
> RESEARCH   FORD
> SALES      ALLEN
> SALES      WARD
> SALES      MARTIN
> SALES      BLAKE
> SALES      TURNER
> SALES      JAMES
>
> val it : {dname:string, ename:string} bag
from d in scott.depts join e in scott.emps on d.deptno = e.deptno
  yield {d.dname, e.ename};
> dname      ename
> ---------- ------
> ACCOUNTING CLARK
> ACCOUNTING KING
> ACCOUNTING MILLER
> RESEARCH   SMITH
> RESEARCH   JONES
> RESEARCH   SCOTT
> RESEARCH   ADAMS
> RESEARCH   FORD
> SALES      ALLEN
> SALES      WARD
> SALES      MARTIN
> SALES      BLAKE
> SALES      TURNER
> SALES      JAMES
>
> val it : {dname:string, ename:string} bag

(* where -> join1 [()] on cond
   'where cond' is a 'join1' against '[()]' with 'on' condition 'cond'
   (then a 'yield' to drop the unit). *)
from d in scott.depts where d.deptno = 10;
> deptno dname      loc
> ------ ---------- --------
>     10 ACCOUNTING NEW YORK
>
> val it : {deptno:int, dname:string, loc:string} bag
from d in scott.depts, u in [()] on d.deptno = 10 yield d;
> deptno dname      loc
> ------ ---------- --------
>     10 ACCOUNTING NEW YORK
>
> val it : {deptno:int, dname:string, loc:string} bag

(* distinct -> coreGroup
   When the row has at least one column, 'distinct' is 'coreGroup' over all of
   them -- group by every column, keeping the keys. Grouping by the only column
   here is exactly that. *)
from e in scott.emps yield e.job distinct;
> val it = ["CLERK","SALESMAN","MANAGER","ANALYST","PRESIDENT"] : string bag
from e in scott.emps group e.job;
> val it = ["CLERK","SALESMAN","MANAGER","ANALYST","PRESIDENT"] : string bag

(*) But when the row has no columns, 'distinct' is NOT 'group {}'. 'distinct'
(*) never increases the row count, so an empty input gives an empty result,
(*) whereas 'group {}' always returns one (grand-total) row. (The zero-column
(*) case desugars instead to '[()]' if the query has a row, else '[]'.)
from e in scott.emps where false yield {} distinct;
> val it = [] : unit bag
from e in scott.emps where false group {};
> val it = [()] : unit bag

(* group -> coreGroup yield
   'group k compute {a = f over arg}' is 'coreGroup' (which pairs each key
   with its 'elements') followed by a 'yield'. The aggregate 'f over arg'
   becomes a query over those elements. *)
from e in scott.emps group e.deptno compute {c = count over ()};
> c deptno
> - ------
> 5     20
> 6     30
> 3     10
>
> val it : {c:int, deptno:int} bag
from e in scott.emps
  group e.deptno compute {es = elements}
  yield {deptno, c = (from e in es compute count over ())};
> c deptno
> - ------
> 5     20
> 6     30
> 3     10
>
> val it : {c:int, deptno:int} bag

(* unorder -> join1 bag [()]
   'unorder' makes an ordered pipeline unordered; joining against an
   unordered '[()]' does the same, since a join is unordered if either
   input is. *)
from i in [1, 2, 3] unorder;
> val it = [1,2,3] : int bag
from i in [1, 2, 3], u in bag [()] yield i;
> val it = [1,2,3] : int bag

(* union -> union1 ...
   'union' with several arguments is 'union1' applied once per argument. *)
from i in [2, 1] union [3], [4, 5];
> val it = [2,1,3,4,5] : int list
from i in [2, 1] union [3] union [4, 5];
> val it = [2,1,3,4,5] : int list

(* except -> except1 ...
   'except' with several arguments is 'except1' applied once per argument. *)
from i in [1, 2, 3, 4, 5] except [2], [4];
> val it = [1,3,5] : int list
from i in [1, 2, 3, 4, 5] except [2] except [4];
> val it = [1,3,5] : int list

(* intersect1 -> except1
   Intersection is derived from difference: 'a intersect b' is
   'a except (a except b)'. *)
from i in [2, 1, 2, 2, 2, 3] intersect [2, 2, 4];
> val it = [2,2] : int list
from i in [2, 1, 2, 2, 2, 3] except (from j in [2, 1, 2, 2, 2, 3] except [2, 2, 4]);
> val it = [2,2] : int list

(* union distinct -> union1 distinct
   A 'distinct' qualifier on a set operator is the plain operator followed
   by a 'distinct' step. *)
from i in [2, 1, 2, 3] union distinct [2, 4];
> val it = [2,1,3,4] : int list
from i in [2, 1, 2, 3] union [2, 4] distinct;
> val it = [2,1,3,4] : int list

(* except distinct -> distinct except1 (b distinct) distinct
   The core expansion makes each side distinct, takes the (multiset)
   difference, and makes the result distinct. *)
from i in [2, 1, 2, 2, 2, 3] except distinct [2, 4];
> val it = [1,3] : int list
from i in [2, 1, 2, 2, 2, 3] distinct except (from j in [2, 4] distinct) distinct;
> val it = [1,3] : int list

(* intersect distinct -> distinct intersect1 (b distinct) distinct
   The set intersection, expanded the same way. *)
from i in [2, 1, 2, 2, 2, 3] intersect distinct [2, 2, 4];
> val it = [2] : int list
from i in [2, 1, 2, 2, 2, 3] distinct intersect (from j in [2, 2, 4] distinct) distinct;
> val it = [2] : int list

(* List.map -> yield, List.filter -> where
   'List.map f' is a 'yield', 'List.filter p' is a 'where'. *)
List.map (fn x => x + 1) [1, 2, 3];
> val it = [2,3,4] : int list
from x in [1, 2, 3] yield x + 1;
> val it = [2,3,4] : int list
List.filter (fn x => x mod 2 = 0) [1, 2, 3, 4];
> val it = [2,4] : int list
from x in [1, 2, 3, 4] where x mod 2 = 0;
> val it = [2,4] : int list

(* Bag.map -> yield, Bag.filter -> where
   The same query operations as 'List.map'/'List.filter', over a bag. *)
Bag.map (fn x => x + 1) (bag [1, 2, 3]);
> val it = [2,3,4] : int bag
from x in bag [1, 2, 3] yield x + 1;
> val it = [2,3,4] : int bag

(* notelem -> not elem
   'x notelem xs' is the negation of membership. *)
from i in [1, 2, 3] where i notelem [2];
> val it = [1,3] : int list
from i in [1, 2, 3] where not (i elem [2]);
> val it = [1,3] : int list

(* current -> {current variables}
   'current' denotes the element flowing through a step; in a multi-scan
   'from' it is the record of the scan variables. *)
from i in [1, 2], s in ["a", "b"] yield current;
> i s
> - -
> 1 a
> 1 b
> 2 a
> 2 b
>
> val it : {i:int, s:string} list
from i in [1, 2], s in ["a", "b"] yield {i, s};
> i s
> - -
> 1 a
> 1 b
> 2 a
> 2 b
>
> val it : {i:int, s:string} list

(* yieldAll -> join1 yield
   'yieldAll e' evaluates 'e' for each row and flattens the results (a
   flatMap): a 'join1' over 'e' then a 'yield' of the element. *)
from x in [[1, 2], [3], [4, 5]] yieldAll x;
> val it = [1,2,3,4,5] : int list
from x in [[1, 2], [3], [4, 5]], v in x yield v;
> val it = [1,2,3,4,5] : int list

(* compute -> only (... group {} compute ...)
   Terminal 'compute agg' reduces the pipeline to one value: 'group {}'
   makes one group, the aggregate runs over it, 'only' takes the row. *)
from e in scott.emps compute sum over e.sal;
> val it = 29025 : real
Relational.only (from e in scott.emps group {} compute (sum over e.sal));
> val it = 29025 : real

(* into -> apply
   Terminal 'into f' feeds the whole pipeline to 'f'. *)
from i in [1, 2, 3] into List.length;
> val it = 3 : int
List.length (from i in [1, 2, 3]);
> val it = 3 : int

(* through pat in f -> scan over f of the pipeline
   'through pat in f' pipes the pipeline through 'f' and scans the result:
   'from pat in (f query)'. *)
from i in [1, 2, 3] through xs in (List.map (fn x => x * 10));
> val it = [10,20,30] : int list
from xs in (List.map (fn x => x * 10) [1, 2, 3]);
> val it = [10,20,30] : int list

(* exists -> Relational.nonEmpty
   'exists scans where cond' tests whether the query has any row. *)
exists e in scott.emps where e.deptno = 10;
> val it = true : bool
Relational.nonEmpty (from e in scott.emps where e.deptno = 10);
> val it = true : bool

(* forall ... require -> not exists
   'forall scans require cond' holds when no row violates 'cond'. *)
forall e in scott.emps require e.sal > 0.0;
> val it = true : bool
not (Relational.nonEmpty (from e in scott.emps where not (e.sal > 0.0)));
> val it = true : bool

(* ---------------------------------------------------------------- *)
(* Primitive and fundamental operators                              *)
(* ---------------------------------------------------------------- *)

(*) 'order' sorts (a core operator); 'skip n' and 'take n' slice an
(*) ordered pipeline (SQL OFFSET and FETCH). None has a simpler form.
from i in [1, 2, 3, 4, 5] skip 1 take 2;
> val it = [2,3] : int list

(* Outer joins are fundamental. 'left join' keeps every left row and makes
   the right side an option ('NONE' where nothing matches); 'right join' is
   its mirror; 'full join' keeps both sides, so both are options. Each is
   filtered to a couple of departments to keep the result small. *)
from d in scott.depts left join e in scott.emps on d.deptno = e.deptno
  where d.deptno elem [10, 40]
  yield {d.dname, ename = Option.map (fn e => e.ename) e};
> dname      ename
> ---------- ------
> ACCOUNTING CLARK
> ACCOUNTING KING
> ACCOUNTING MILLER
> OPERATIONS
>
> val it : {dname:string, ename:string option} bag
from e in scott.emps right join d in scott.depts on e.deptno = d.deptno
  where d.deptno elem [10, 40]
  yield {d.dname, ename = Option.map (fn e => e.ename) e};
> dname      ename
> ---------- ------
> ACCOUNTING CLARK
> ACCOUNTING KING
> ACCOUNTING MILLER
> OPERATIONS
>
> val it : {dname:string, ename:string option} bag
from e in (from x in scott.emps where x.ename elem ["SMITH", "CLARK"])
  full join d in (from y in scott.depts where y.deptno elem [10, 40])
    on e.deptno = d.deptno
  yield {dept = Option.map (fn d => d.dname) d,
      emp = Option.map (fn e => e.ename) e};
> dept       emp
> ---------- -----
>            SMITH
> ACCOUNTING CLARK
> OPERATIONS
>
> val it : {dept:string option, emp:string option} bag

(* ordinal -> enumerate
   'enumerate' has no surface syntax, but the sugar 'ordinal' exposes the
   position, so yielding each element with its 'ordinal' is what
   'enumerate' would produce. *)
from e in [{name = "Ann"}, {name = "Bob"}, {name = "Cy"}] yield {e, ordinal};
> e    ordinal
> name
> ---- -------
> Ann        0
> Bob        1
> Cy         2
>
> val it : {e:{name:string}, `ordinal`:int} list

(* unbounded -> join over each variable's extent
   A 'from' may bind a variable with no collection ('i' and 'j' here). A
   'where' that pins each one to a finite set gives it an extent, and each
   extent becomes a 'join'. ('Sys.planEx "3"' prints the expanded form.) *)
from {deptno, ...} in scott.depts, i, j
  where i = deptno andalso j elem [i + 1, i + 2];
> deptno i  j
> ------ -- --
>     10 10 11
>     10 10 12
>     20 20 21
>     20 20 22
>     30 30 31
>     30 30 32
>     40 40 41
>     40 40 42
>
> val it : {deptno:int, i:int, j:int} bag
from {deptno, ...} in scott.depts join i in [deptno] join j in [i + 1, i + 2];
> deptno i  j
> ------ -- --
>     10 10 11
>     10 10 12
>     20 20 21
>     20 20 22
>     30 30 31
>     30 30 32
>     40 40 41
>     40 40 42
>
> val it : {deptno:int, i:int, j:int} bag

(*) End desugaring.smli
