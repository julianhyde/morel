 *
 * Query desugaring and the core operators
 * =======================================
 *
 * Morel's query language is large: 'from' with multiple scans,
 * 'where', 'group', 'compute', 'distinct', 'order', 'union',
 * 'intersect', 'except', 'unorder', and so on. But its meaning can be
 * explained in terms of a small set of "core" operators. Every other
 * construct is "sugar" that desugars into a combination of core
 * operators.
 *
 * This script names each desugaring rule (for example,
 * 'distinct -> coreGroup') and, for each, gives two queries that
 * produce the same result: the first written with sugar, the second
 * written using only the operators it desugars to. Running both and
 * seeing identical output is a check that the rule holds.
 *
 * The core operators are:
 *
 *   - 'fromUnit', the empty pipeline 'from', a collection of one
 *     zero-field element, where every query starts;
 *   - 'join1', add one scan 'pat in exp [on cond]' to a pipeline;
 *   - 'yield', map each element to a new value;
 *   - 'order', sort the elements;
 *   - 'coreGroup', gather elements that share a key, without applying
 *     any aggregate function;
 *   - 'union1', concatenate one more collection;
 *   - 'except1', remove the elements of one more collection;
 *   - 'enumerate', pair each element with its ordinal.
 *
 * Some of these operators ('coreGroup', 'join1', 'union1', 'except1',
 * 'enumerate') have no surface syntax of their own; where that is so,
 * the "core" query below expresses them using the nearest primitive
 * that does. A 'todo:' section at the end lists the rules not yet
 * covered.
 *)

(*) Load the 'scott' database (emps, depts, ...). The examples draw on
(*) 'scott.emps' and 'scott.depts'.
useSilently "../scott.smli";
> [opening ../scott.smli]
> val it = () : unit

set ("output", "tabular");
> val it = () : unit

(* ---------------------------------------------------------------- *)
(* The core operators                                               *)
(* ---------------------------------------------------------------- *)

(*) 'fromUnit' is the empty 'from'. It yields a single zero-field
(*) element, so a pipeline built on it has exactly one row to start.
from;
> val it = [()] : unit list

(*) 'join1' adds a scan to a pipeline. A 'from' with two scans is two
(*) 'join1's; each row pairs an element from the left with one from the
(*) right (a Cartesian product, optionally filtered by 'on').
from i in [1, 2], j in [10, 20] yield i + j;
> val it = [11,21,12,22] : int list

(*) 'yield' maps each element to a new value.
from d in scott.depts yield d.dname;
> val it = ["ACCOUNTING","OPERATIONS","RESEARCH","SALES"] : string bag

(*) 'order' sorts the elements. The result is always a list.
from d in scott.depts order DESC d.deptno yield d.dname;
> val it = ["OPERATIONS","SALES","RESEARCH","ACCOUNTING"] : string list

(*) 'coreGroup' gathers the elements that share a key into a group. It
(*) does not apply aggregate functions; the group's elements are kept
(*) verbatim. Morel has no 'coreGroup' keyword, so we use the closest
(*) primitive, 'group k compute {es = elements}', which pairs each key
(*) with its elements.
from e in [{job = "A", x = 1}, {job = "A", x = 2}, {job = "B", x = 3}]
  group e.job compute {elements};
> elements job
> job x
> --- ---- ---
> A      1 A
> A      2
> B      3 B
>
> val it : {`elements`:{job:string, x:int} list, job:string} list

(*) 'union1' concatenates one more collection (like SQL 'UNION ALL').
from i in [1, 2] union [2, 3];
> val it = [1,2,2,3] : int list

(*) 'except1' removes the elements of one more collection (like SQL
(*) 'EXCEPT ALL': one element is removed per matching element).
from i in [1, 2, 2, 3] except [2];
> val it = [1,2,3] : int list

(*) 'enumerate' pairs each element with its ordinal. It has no surface
(*) syntax; see the 'todo:' section.

(* ---------------------------------------------------------------- *)
(* Desugaring rules (fundamental concepts first)                    *)
(* ---------------------------------------------------------------- *)

(* from -> fromUnit join1
   A 'from' with one scan is 'fromUnit' (the one-element pipeline '[()]')
   followed by a 'join1' that adds the scan. *)
from e in scott.emps where e.deptno = 10 yield e.ename order current;
> val it = ["CLARK","KING","MILLER"] : string list
from u in [()], e in scott.emps where e.deptno = 10 yield e.ename order current;
> val it = ["CLARK","KING","MILLER"] : string list

(* scan p = exp -> scan p in [exp]
   A scan that binds a variable to a single value, 'p = exp', is a scan
   over the one-element list '[exp]'. 'exp' may depend on earlier scans. *)
from b in ["John", "Paul", "George", "Ringo"],
  len = size b;
> b      len
> ------ ---
> John     4
> Paul     4
> George   6
> Ringo    5
>
> val it : {b:string, len:int} list
from b in ["John", "Paul", "George", "Ringo"]
  join len in [size b];
> b      len
> ------ ---
> John     4
> Paul     4
> George   6
> Ringo    5
>
> val it : {b:string, len:int} list

(* scan {f1, f2 = const, ...} in t -> where yield
   A record pattern in a scan splits into two parts: each field matched against
   a constant becomes a 'where', and each field bound to a variable becomes a
   'yield'. So '{deptno = 10, ename, sal, ...}' filters on 'deptno = 10' and
   yields '{ename, sal}'. *)
from {deptno = 10, ename, sal, ...} in scott.emps;
> ename  sal
> ------ ----
> CLARK  2450
> KING   5000
> MILLER 1300
>
> val it : {ename:string, sal:real} bag
from e in scott.emps where e.deptno = 10 yield {e.ename, e.sal};
> ename  sal
> ------ ----
> CLARK  2450
> KING   5000
> MILLER 1300
>
> val it : {ename:string, sal:real} bag

(* join -> join1 ...
   A 'from' with several scans is one 'join1' per scan. An 'on'
   condition rides along with its scan's 'join1'. *)
from e in scott.emps,
    d in scott.depts on e.deptno = d.deptno
  where e.deptno = 20
  yield {e.ename, d.loc};
> ename loc
> ----- ------
> SMITH DALLAS
> JONES DALLAS
> SCOTT DALLAS
> ADAMS DALLAS
> FORD  DALLAS
>
> val it : {ename:string, loc:string} bag
from e in scott.emps
  join d in scott.depts on e.deptno = d.deptno
  where e.deptno = 20
  yield {e.ename, d.loc};
> ename loc
> ----- ------
> SMITH DALLAS
> JONES DALLAS
> SCOTT DALLAS
> ADAMS DALLAS
> FORD  DALLAS
>
> val it : {ename:string, loc:string} bag

(* where -> join1 [()] on cond
   'where cond' is a 'join1' against the one-element pipeline '[()]'
   whose 'on' condition is 'cond': the row survives if 'cond' holds. *)
from e in scott.emps where e.deptno = 10 yield e.ename;
> val it = ["CLARK","KING","MILLER"] : string bag
from e in scott.emps, u in [()] on e.deptno = 10 yield e.ename;
> val it = ["CLARK","KING","MILLER"] : string bag

(* distinct -> coreGroup
   'distinct' removes duplicates by grouping on every column and keeping
   the keys. Grouping by all columns ('group {...}') is exactly that. *)
from e in scott.emps yield {e.job} distinct;
> job
> ---------
> CLERK
> SALESMAN
> MANAGER
> ANALYST
> PRESIDENT
>
> val it : {job:string} bag
from e in scott.emps group {e.job};
> job
> ---------
> CLERK
> SALESMAN
> MANAGER
> ANALYST
> PRESIDENT
>
> val it : {job:string} bag

(* group -> coreGroup yield
   'group k compute {a = f over arg}' is 'coreGroup' (which pairs each key with
   its 'elements') followed by a 'yield'. Each aggregate 'f over arg' becomes a
   query over those elements -- 'from e in elements compute f over arg' -- so
   'count over ()' counts the elements, and 'sum over e.sal' sums a projection
   of them. *)
from e in scott.emps
  group e.deptno compute {c = count over (), s = sum over e.sal};
> c deptno s
> - ------ -----
> 5     20 10875
> 6     30  9400
> 3     10  8750
>
> val it : {c:int, deptno:int, s:real} bag
from e in scott.emps
  group e.deptno compute {es = elements}
  yield {deptno,
      c = (from e in es compute count over ()),
      s = (from e in es compute sum over e.sal)};
> c deptno s
> - ------ -----
> 5     20 10875
> 6     30  9400
> 3     10  8750
>
> val it : {c:int, deptno:int, s:real} bag

(* unorder -> join1 bag [()]
   'unorder' turns an ordered pipeline into an unordered one.
   The result is always a bag.
   Joining
   against an unordered one-element collection 'bag [()]' does the
   same, because a join is unordered if either input is. *)
from i in [1, 2, 3] unorder;
> val it = [1,2,3] : int bag
from i in [1, 2, 3], u in bag [()] yield i;
> val it = [1,2,3] : int bag

(* union -> union1 ...
   'union' with several arguments is 'union1' applied once per
   argument. *)
from i in [2, 1] union [3], [4, 5];
> val it = [2,1,3,4,5] : int list
from i in [2, 1] union [3] union [4, 5];
> val it = [2,1,3,4,5] : int list

(* except -> except1 ...
   'except' with several arguments is 'except1' applied once per
   argument. *)
from i in [1, 2, 3, 4, 5] except [2], [4];
> val it = [1,3,5] : int list
from i in [1, 2, 3, 4, 5] except [2] except [4];
> val it = [1,3,5] : int list

(* intersect1 -> except1
   Intersection is derived from difference: 'a intersect b' is
   'a except (a except b)'. *)
from i in [2, 1, 2, 2, 2, 3] intersect [2, 2, 4];
> val it = [2,2] : int list
from i in [2, 1, 2, 2, 2, 3] except (from j in [2, 1, 2, 2, 2, 3] except [2, 2, 4]);
> val it = [2,2] : int list

(* union distinct -> union1 distinct
   A 'distinct' qualifier on a set operator desugars to the plain
   operator followed by a 'distinct' step. *)
from i in [2, 1, 2, 3] union distinct [2, 4];
> val it = [2,1,3,4] : int list
from i in [2, 1, 2, 3] union [2, 4] distinct;
> val it = [2,1,3,4] : int list

(* List.map -> yield
   'List.map f xs' is a query that yields 'f' of each element. *)
List.map (fn x => x + 1) [1, 2, 3];
> val it = [2,3,4] : int list
from x in [1, 2, 3] yield x + 1;
> val it = [2,3,4] : int list

(* List.filter -> where
   'List.filter p xs' is a query that keeps the elements satisfying
   'p'. *)
List.filter (fn x => x mod 2 = 0) [1, 2, 3, 4];
> val it = [2,4] : int list
from x in [1, 2, 3, 4] where x mod 2 = 0;
> val it = [2,4] : int list

(* current -> {current variables}
   'current' denotes the element currently
   flowing through a step. In a single-scan 'from' it equals the scan
   variable. *)
from i in [1, 2]
  join s in ["a", "b"]
  yield current;
> i s
> - -
> 1 a
> 1 b
> 2 a
> 2 b
>
> val it : {i:int, s:string} list
from i in [1, 2]
  join s in ["a", "b"]
  yield {i, s};
> i s
> - -
> 1 a
> 1 b
> 2 a
> 2 b
>
> val it : {i:int, s:string} list

(* yieldAll -> join1 yield
   'yieldAll e' evaluates the collection 'e' for each row and flattens the
   results into the pipeline (a flatMap). It is a 'join1' over 'e' followed by
   a 'yield' of the joined element: ', v in e yield v'. *)
from x in [[1, 2], [3], [4, 5]] yieldAll x;
> val it = [1,2,3,4,5] : int list
from x in [[1, 2], [3], [4, 5]], v in x yield v;
> val it = [1,2,3,4,5] : int list

(* compute -> only (... group {} compute ...)
   The terminal 'compute agg' reduces the whole pipeline to one value. Grouping
   by the empty key ('group {}') makes a single group; the aggregate runs over
   it; 'Relational.only' takes that one row. *)
from e in scott.emps compute sum over e.sal;
> val it = 29025 : real
Relational.only (from e in scott.emps group {} compute (sum over e.sal));
> val it = 29025 : real

(* into -> apply
   The terminal 'into f' feeds the whole pipeline to the function 'f'. It is
   just 'f' applied to the query. *)
from i in [3, 1, 2] yield i + 1 into List.length;
> val it = 3 : int
List.length (from i in [3, 1, 2] yield i + 1);
> val it = 3 : int

(* exists -> Relational.nonEmpty
   'exists scans where cond' tests whether the query has any row. It is
   'Relational.nonEmpty' applied to the corresponding 'from'. *)
exists e in scott.emps where e.deptno = 10;
> val it = true : bool
Relational.nonEmpty (from e in scott.emps where e.deptno = 10);
> val it = true : bool

(* forall ... require -> not exists
   'forall scans require cond' tests whether every row satisfies 'cond'. It
   holds when no row violates it: 'not exists (scans where not cond)'. *)
forall e in scott.emps require e.sal > 0.0;
> val it = true : bool
not (Relational.nonEmpty (from e in scott.emps where not (e.sal > 0.0)));
> val it = true : bool

(* ---------------------------------------------------------------- *)
(* todo: rules not yet covered                                      *)
(* ---------------------------------------------------------------- *)

(* The remaining query operators are either primitive (no simpler form) or
   not yet documented:

   - 'skip' and 'take' slice an ordered pipeline (like SQL OFFSET / FETCH).
     They are primitive ordered operators with no simpler desugaring.
   - 'through pat in f' pipes the whole pipeline through the function 'f' and
     scans the result, e.g. 'from i in xs through j in (sort)'. (As of
     writing, a trailing 'through' as the final step hits a compiler bug, so
     it is not illustrated here.) *)

(* todo: ordinal -> enumerate
   'ordinal' (the position of the current element) is meant to desugar
   into an 'enumerate' step that pairs each element with its position.
   'enumerate' has no surface syntax, so only the sugared form runs
   today:
     from e in scott.emps order e.ename yield {e.ename, ordinal} *)

(* todo: bag operations
   'Bag.map' and 'Bag.filter' desugar to query operations on bags, just
   as 'List.map' and 'List.filter' do for lists. *)

(* todo: except distinct, intersect distinct
   The distinct-qualified forms of 'except' and 'intersect' have more
   involved desugarings (each argument is made distinct, and the result
   is made distinct) than 'union distinct', and are not illustrated here. *)

(* todo: left/right/full join
   Outer joins ('join pat in exp on cond' qualified by 'left', 'right' or
   'full') pad unmatched rows with NULL; their desugaring is not illustrated
   here. *)

(* unbounded -> join over each variable's extent
   A 'from' may bind a variable without a collection: 'i' and 'j' here are
   "unbounded". A 'where' that pins each one to a finite set of values gives
   it an extent, and each extent becomes a 'join'. 'i = deptno' makes 'i'
   range over '[deptno]'; 'j elem [i + 1, i + 2]' makes 'j' range over
   '[i + 1, i + 2]'. ('Sys.planEx "3"' prints this expanded form.) *)
from {deptno, dname, loc} in scott.depts,
    i,
    j
  where i = deptno
  andalso j elem [i + 1, i + 2];
> deptno dname      i  j  loc
> ------ ---------- -- -- --------
>     10 ACCOUNTING 10 11 NEW YORK
>     10 ACCOUNTING 10 12 NEW YORK
>     20 RESEARCH   20 21 DALLAS
>     20 RESEARCH   20 22 DALLAS
>     30 SALES      30 31 CHICAGO
>     30 SALES      30 32 CHICAGO
>     40 OPERATIONS 40 41 BOSTON
>     40 OPERATIONS 40 42 BOSTON
>
> val it : {deptno:int, dname:string, i:int, j:int, loc:string} bag
from {deptno, dname, loc} in scott.depts
  join i in [deptno]
  join j in [i + 1, i + 2];
> deptno dname      i  j  loc
> ------ ---------- -- -- --------
>     10 ACCOUNTING 10 11 NEW YORK
>     10 ACCOUNTING 10 12 NEW YORK
>     20 RESEARCH   20 21 DALLAS
>     20 RESEARCH   20 22 DALLAS
>     30 SALES      30 31 CHICAGO
>     30 SALES      30 32 CHICAGO
>     40 OPERATIONS 40 41 BOSTON
>     40 OPERATIONS 40 42 BOSTON
>
> val it : {deptno:int, dname:string, i:int, j:int, loc:string} bag

(*) End desugaring.smli
