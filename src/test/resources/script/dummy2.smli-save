(*) Polymorphic agg applied to list
from i in [1, 2, 3]
  compute Fn.id over i;
> val it = [1,2,3] : int list

(*) Polymorphic agg applied to bag
from i in bag [1, 2, 3]
  compute Fn.id over i;
> val it = [1,2,3] : int bag

(*) Bag agg applied to bag
from i in bag [1, 2, 3]
  compute sum over i;
> val it = 6 : int

(*) Bag agg applied to list
from i in [1, 2, 3]
  compute sum over i;
> val it = 6 : int

(*) List agg applied to bag
from i in bag [1, 2, 3]
  compute List.tl over i;
> val it = [2,3] : int list

(*) List agg applied to list
from i in [1, 2, 3]
  compute List.tl over i;
> val it = [2,3] : int list

