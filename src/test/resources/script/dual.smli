 *
 * Queries that must give the same answer whether evaluated
 * locally or pushed down to Apache Calcite.
 *
 * Morel-Java's suite runs this script twice (see
 * ScriptTest.testScriptDual): once in local mode, and once in
 * Calcite ("hybrid") mode with a tracer that fails if any query is
 * not pushed down. So do not add queries that cannot be pushed down,
 * and do not call Sys.plan (whose output differs between modes).
 *
 * Morel-Rust cannot push queries down to SQL, so runs this test
 * only in local mode.
 *)

(* Configuration statements cannot be pushed down; the tracer's deny list
 * exempts calls to the Sys structure. *)
Sys.set ("printLength", 64);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit
Sys.set ("output", "tabular");
> val it = () : unit

from;
> val it = [()] : unit list
from e in scott.emps;
