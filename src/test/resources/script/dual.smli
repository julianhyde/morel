from i in [1, 2, 3] union [2, 5, 4];
> val it = [1,2,3,2,5,4] : int list
from i in [1, 2, 3] union [2, 5, 4], [2, 1, 7];
> val it = [1,2,3,2,5,4,2,1,7] : int list
from i in [1, 2, 3] intersect [2, 5, 4];
> val it = [2] : int list
from i in [1, 2, 3] intersect [2, 5, 4], [2, 1, 6];
> val it = [2] : int list
from i in [1, 2, 3] intersect [1, 2, 3], [99];
> val it = [] : int list
from i in [1, 2, 3] except [2, 5, 4];
> val it = [1,3] : int list
from i in [1, 2, 3] except [2, 5, 4], [2, 1, 6];
> val it = [3] : int list
from i in [10, 15, 20] union (from d in scott.depts yield d.deptno);
> val it = [10,15,20,10,20,30,40] : int bag
from i in [10, 15, 20] except (from d in scott.depts yield d.deptno);
> val it = [15] : int bag
from i in [10, 15, 20] intersect (from d in scott.depts yield d.deptno);
> val it = [10,20] : int bag

(*) The following 4 are equivalent.
from e in scott.emps where e.deptno = 30 yield e.empno;
> val it = [7499,7521,7654,7698,7844,7900] : int bag
let
  val emps = #emps scott
in
  from e in emps
  where e.deptno = 30
  yield e.empno
end;
> val it = [7499,7521,7654,7698,7844,7900] : int bag

let
  val emps = #emps scott
  val thirty = 30
in
  from e in emps
  where e.deptno = thirty
  yield e.empno
end;
> val it = [7499,7521,7654,7698,7844,7900] : int bag

Bag.map (fn e => (#empno e))
  (Bag.filter (fn e => (#deptno e) = 30) (#emps scott));
> val it = [7499,7521,7654,7698,7844,7900] : int bag

(*) Intersect, except, concat via List methods
List.`except` [[1, 2, 3], [2, 5, 4]];
> val it = [1,3] : int list
List.`intersect` [[1, 2, 3], [2, 5, 4]];
> val it = [2] : int list
List.`except` [[1, 2, 3], [2, 5, 4], [2, 1, 6]];
> val it = [3] : int list
List.`intersect` [[1, 2, 3], [2, 5, 4], [2, 1, 6]];
> val it = [2] : int list
List.`except` [[1, 1, 2, 3], [1]];
> val it = [1,2,3] : int list
List.`intersect` [[1, 1, 2, 3], [1, 1, 5]];
> val it = [1,1] : int list
List.concat [[1, 2], [3], [4, 5]];
> val it = [1,2,3,4,5] : int list

