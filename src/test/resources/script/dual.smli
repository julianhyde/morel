from n in [1,2,3] yield n;
> val it = [1,2,3] : int list
from n in [1,2,3] where n mod 2 = 1 andalso n < 3 yield n;
> val it = [1] : int list
from n in [1,2,3] where false yield n;
> val it = [] : int list
from n in [1,2,3] where n < 2 orelse n > 2 yield n * 3;
> val it = [3,9] : int list
from r in [{a=1,b=2},{a=1,b=0},{a=2,b=1}]
  order (DESC r.a, r.b)
  yield {r.a, b10 = r.b * 10};
> a b10
> - ---
> 2  10
> 1   0
> 1  20
>
> val it : {a:int, b10:int} list

from r in [{a=2,b=3},{a=2,b=1},{a=1,b=1}]
  group r.a
  order a;
> val it = [1,2] : int list

from r in [{a=2,b=3},{a=2,b=1},{a=1,b=1}]
  group {} compute sum over r.b;
> val it = [5] : int list

from r in [{a=2,b=3},{a=2,b=1},{a=1,b=1}]
  group r.a
  yield a
  order a;
> val it = [1,2] : int list

from r in [{a=2,b=3}]
group r.b compute {sb = sum over r.b,
    mb = min over r.b, a = count over ()};
> a b mb sb
> - - -- --
> 1 3  3  3
>
> val it : {a:int, b:int, mb:int, sb:int} list

from r in [{a=2,b=3}]
group r.b compute {sb = sum over r.b,
    mb = min over r.b, a = count over ()}
yield {a, a2 = a + b, sb};
> a a2 sb
> - -- --
> 1  4  3
>
> val it : {a:int, a2:int, sb:int} list

(* 'max' and 'min' over an empty collection raise 'Empty', in both local and
 * Calcite mode, and at the same position. Here the collection is empty
 * because the filter removes every row. *)
from e in scott.emps where e.deptno < 0 compute max over e.empno;
> uncaught exception Empty
>   raised at: stdIn:1.49-1.65
from e in scott.emps where e.deptno < 0 compute min over e.empno;
> uncaught exception Empty
>   raised at: stdIn:1.49-1.65

(* In a record 'compute', 'max' over the empty collection still raises
 * 'Empty' (though 'count' would return 0); both modes raise it at the
 * 'max over e.sal' call. *)
from e in scott.emps where e.deptno < 0
  compute {c = count over (), m = max over e.sal};
> uncaught exception Empty
>   raised at: stdIn:2.35-2.49

