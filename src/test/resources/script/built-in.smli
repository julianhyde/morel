(* "val ~ : int -> int" maps to "Int.~"; overloaded for real *)
op ~;
> val it = fn : int -> int
~ 5;
> val it = ~5 : int
~ 3.5;
> val it = ~3.5 : real
(* "val + : int * int -> int" maps to "Int.+" *)
op +;
> val it = fn : int * int -> int
(* "val - : int * int -> int" maps to "Int.-" *)
op -;
> val it = fn : int * int -> int
(* "val * : int * int -> int" maps to "Int.*" *)
op *;
> val it = fn : int * int -> int
(* "val @ : ('a list * 'a list) -> 'a list" maps to "List.@" *)
op @;
> val it = fn : 'a list * 'a list -> 'a list
(* "val ^ : string * string -> string" maps to "String.^" *)
op ^;
> val it = fn : string * string -> string
(* "val abs : int -> int" maps to "Int.abs"; overloaded for real *)
abs;
> val it = fn : 'a -> 'a
abs ~3;
> val it = 3 : int
abs (valOf Int.minInt);
> uncaught exception Overflow
>   raised at: stdIn:1.1-1.22
abs ~3.5;
> val it = 3.5 : real
