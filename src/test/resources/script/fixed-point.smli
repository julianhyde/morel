(* 4. Lollipop ---------------------------------------------------- *)
(*) In Datalog:
(*)   Lollipop(x, y, z, w) :- R(x, y), S(y, z), T(x, z), U(x, w).
from x, y, z, w
  where (x, y) elem western_pairs
    andalso (y, z) elem western_pairs
    andalso (x, z) elem western_pairs
    andalso (x, w) elem western_pairs
    andalso w <> y
    andalso y <> z
  order (w, x, y, z);
