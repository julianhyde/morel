>    {dist=2,node="CO"},{dist=9,node="CT"},{dist=7,node="DC"},{dist=8,node="DE"},
>    {dist=7,node="FL"},{dist=6,node="GA"},{dist=4,node="IA"},{dist=2,node="ID"},
>    {dist=5,node="IL"},{dist=6,node="IN"},{dist=3,node="KS"},{dist=5,node="KY"},
>    {dist=4,node="LA"},{dist=9,node="MA"},{dist=7,node="MD"},{dist=11,node="ME"},
>    {dist=6,node="MI"},{dist=5,node="MN"},{dist=4,node="MO"},{dist=5,node="MS"},
>    {dist=3,node="MT"},{dist=6,node="NC"},{dist=4,node="ND"},{dist=3,node="NE"},
>    {dist=10,node="NH"},{dist=8,node="NJ"},{dist=2,node="NM"},{dist=1,node="NV"},
